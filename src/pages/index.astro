---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroScene from '../components/HeroScene.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = allPosts[0];

const base = '/Circle-of-Life';
const CATS = [
  { label: 'Neuroscience', sub: "BCI · Alzheimer's · Neuromod",   color: '#EF5B5B', href: `${base}/blog/neuroscience/` },
  { label: 'Metabolism',   sub: 'MASH · GLP-1 · Liver · Insulin', color: '#F7E623', href: `${base}/blog/metabolism/`   },
  { label: 'Immunology',   sub: 'CAR-T · Checkpoint · Aging',      color: '#3D50B3', href: `${base}/blog/immunology/`  },
];
---
<html lang="en">
<head>
  <BaseHead title="Circle of Life" description="Curated biotech insights for researchers, investors, and industry professionals." />
</head>
<body>
  <Header />
  <HeroScene />
  <main>

    {/* Latest article — title + tags only */}
    {latest && (
      <section class="latest-section">
        <span class="section-label">— Latest Article</span>
        <a href={`${base}/blog/${latest.id}/`} class="latest-row">
          <h2 class="latest-title">{latest.data.title}</h2>
          <div class="latest-tags">
            {latest.data.tags?.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </a>
      </section>
    )}

    {/* Category cards — click to go to filtered article list */}
    <section class="cat-grid">
      {CATS.map(cat => (
        <a href={cat.href} class="cat-card" style={`--cc:${cat.color}`}>
          <div class="cat-card-top" style={`border-top: 5px solid ${cat.color}`}>
            <span class="cat-card-label">{cat.label}</span>
            <span class="cat-card-sub">{cat.sub}</span>
          </div>
          <span class="cat-card-cta">Read Articles →</span>
        </a>
      ))}
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
.latest-section {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid #000;
}
.section-label {
  display: block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.42);
  margin-bottom: 1rem;
}
.latest-row { display: block; text-decoration: none; transition: opacity 0.15s; }
.latest-row:hover { opacity: 0.7; }
.latest-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  line-height: 1.05;
  color: #000;
  margin: 0 0 0.8rem;
  border: none; padding: 0;
}
.latest-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

/* ── Category cards ── */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 2.5px solid #000;
  box-shadow: 8px 8px 0 #000;
  margin-bottom: 3rem;
}
.cat-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0;
  text-decoration: none;
  border-right: 2px solid #000;
  background: #fff;
  transition: background 0.15s;
  min-height: 180px;
}
.cat-card:last-child { border-right: none; }
.cat-card:hover { background: #000; }
.cat-card:hover .cat-card-label,
.cat-card:hover .cat-card-sub,
.cat-card:hover .cat-card-cta { color: #F2EFE6 !important; }

.cat-card-top {
  padding: 1.4rem 1.6rem 1rem;
  flex: 1;
}
.cat-card-label {
  font-family: 'Archivo Black', sans-serif;
  font-size: 1rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #000;
  display: block;
  margin-bottom: 0.5rem;
}
.cat-card-sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: rgba(0,0,0,0.52);
  line-height: 1.5;
}
.cat-card-cta {
  display: block;
  padding: 0.9rem 1.6rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cc);
  border-top: 1px solid rgba(0,0,0,0.1);
  transition: color 0.15s;
}

@media (max-width: 680px) {
  .cat-grid { grid-template-columns: 1fr; }
  .cat-card { border-right: none; border-bottom: 2px solid #000; min-height: auto; }
  .cat-card:last-child { border-bottom: none; }
}
</style>
