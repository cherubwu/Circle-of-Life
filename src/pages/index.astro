---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroScene from '../components/HeroScene.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const PANEL_COLOURS = ['#EF5B5B', '#F7E623', '#3D50B3', '#E61E8D', '#1d8a78'];
---
<html lang="en">
<head>
  <BaseHead title="Circle of Life" description="Curated biotech insights for researchers, investors, and industry professionals." />
</head>
<body>
  <Header />
  <HeroScene />
  <main>
    <section>
      <h2>Latest Articles</h2>
      <ul class="post-list">
        {posts.map((post, i) => (
          <li class="post-card">
            <span class="card-accent" style={`background:${PANEL_COLOURS[i % PANEL_COLOURS.length]}`}></span>
            <div class="card-body">
              <div class="card-meta">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
              </div>
              <a href={`/Circle-of-Life/blog/${post.id}/`} class="post-title">{post.data.title}</a>
              <p class="desc">{post.data.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
.post-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.2rem; }

.post-card {
  display: flex;
  border: 2.5px solid #000;
  background: #fff;
  box-shadow: 6px 6px 0 #000;
  overflow: visible;
  transition: transform 0.15s, box-shadow 0.15s;
}
.post-card:hover {
  transform: translate(-3px, -3px);
  box-shadow: 9px 9px 0 #000;
}

.card-accent {
  width: 10px;
  flex-shrink: 0;
}

.card-body {
  padding: 1.4rem 1.6rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  min-width: 0;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.42);
}

.post-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: 1.15rem;
  line-height: 1.15;
  color: #000 !important;
  text-decoration: none;
  display: block;
  transition: color 0.12s;
}
.post-title:hover { color: #E61E8D !important; text-decoration: none; }

.desc {
  color: rgba(0,0,0,0.55);
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.65;
  font-family: 'DM Sans', sans-serif;
}
</style>
