---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroScene from '../../components/HeroScene.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = allPosts[0];

const NEURO_TAGS   = ['脑机接口','神经科学','神经','brain','bci','neuroscience','alzheimer','parkinson'];
const METABOL_TAGS = ['mash','代谢','代谢物','肝代谢','glp','胰岛素','线粒体','metabolism'];
const IMMUNE_TAGS  = ['免疫','car-t','检查点','自身免疫','衰老','胸腺','immunology','immune'];

function inCategory(post: any, keywords: string[]) {
  const tags = (post.data.tags ?? []).map((t: string) => t.toLowerCase());
  return tags.some((t: string) => keywords.some(k => t.includes(k.toLowerCase())));
}

const neuroPosts   = allPosts.filter(p => inCategory(p, NEURO_TAGS));
const metabolPosts = allPosts.filter(p => inCategory(p, METABOL_TAGS));
const immunePosts  = allPosts.filter(p => inCategory(p, IMMUNE_TAGS));

const CATS = [
  { id: 'neuro',   label: '神经科学', color: '#EF5B5B', posts: neuroPosts   },
  { id: 'metabol', label: '代谢',     color: '#F7E623', posts: metabolPosts },
  { id: 'immune',  label: '免疫学',   color: '#3D50B3', posts: immunePosts  },
];
---
<html lang="zh">
<head>
  <BaseHead title="生之回环 · Circle of Life" description="面向生物科技从业者、投资人与研究者的策展 + 洞见平台，聚焦创新药与神经科学前沿。" />
</head>
<body>
  <Header />
  <HeroScene />
  <main>

    {latest && (
      <section class="latest-section">
        <span class="section-label">— 最新文章</span>
        <a href={`/Circle-of-Life/zh/blog/${latest.id}/`} class="latest-row">
          <h2 class="latest-title">{latest.data.title}</h2>
          <div class="latest-tags">
            {latest.data.tags?.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </a>
      </section>
    )}

    <section class="cat-grid">
      {CATS.map(cat => (
        <div class="cat-col">
          <div class="cat-header" style={`border-top: 4px solid ${cat.color}`}>
            <span class="cat-label" style={`color: ${cat.color}`}>{cat.label}</span>
          </div>
          {cat.posts.length === 0
            ? <p class="cat-empty">即将上线</p>
            : cat.posts.map(post => (
                <a href={`/Circle-of-Life/zh/blog/${post.id}/`} class="cat-item">
                  <span class="cat-item-title">{post.data.title}</span>
                  <div class="cat-item-tags">
                    {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                </a>
              ))
          }
        </div>
      ))}
    </section>

  </main>
  <Footer />
</body>
</html>

<style>
.latest-section {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 2px solid #000;
}
.section-label {
  display: block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.42);
  margin-bottom: 1rem;
}
.latest-row { display: block; text-decoration: none; transition: opacity 0.15s; }
.latest-row:hover { opacity: 0.72; }
.latest-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(1.5rem, 3vw, 2.4rem);
  line-height: 1.1;
  color: #000;
  margin: 0 0 0.8rem;
  border: none; padding: 0;
}
.latest-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

.cat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 2.5px solid #000;
  box-shadow: 8px 8px 0 #000;
}
.cat-col { border-right: 2px solid #000; padding: 0 0 1.5rem; }
.cat-col:last-child { border-right: none; }
.cat-header { padding: 1rem 1.4rem 0.8rem; margin-bottom: 0.5rem; }
.cat-label {
  font-family: 'Archivo Black', sans-serif;
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.cat-item {
  display: block;
  padding: 0.9rem 1.4rem;
  text-decoration: none;
  border-top: 1px solid rgba(0,0,0,0.08);
  transition: background 0.12s;
}
.cat-item:hover { background: #000; }
.cat-item:hover .cat-item-title { color: #F2EFE6; }
.cat-item:hover .tag { background: #F2EFE6; color: #000; }
.cat-item-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 600;
  line-height: 1.3;
  color: #000;
  display: block;
  margin-bottom: 0.5rem;
}
.cat-item-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
.cat-empty {
  padding: 1rem 1.4rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(0,0,0,0.3);
  letter-spacing: 0.06em;
  margin: 0;
}
@media (max-width: 680px) {
  .cat-grid { grid-template-columns: 1fr; }
  .cat-col { border-right: none; border-bottom: 2px solid #000; }
  .cat-col:last-child { border-bottom: none; }
}
</style>
