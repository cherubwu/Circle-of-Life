---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroScene from '../../components/HeroScene.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<html lang="zh">
<head>
  <BaseHead title="生之回环 · Circle of Life" description="面向生物科技从业者、投资人与研究者的策展 + 洞见平台，聚焦创新药与神经科学前沿。" />
</head>
<body>
  <Header />
  <HeroScene />
  <main>
    <section>
      <h2>最新文章</h2>
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <a href={`/Circle-of-Life/zh/blog/${post.id}/`}>{post.data.title}</a>
            <span class="meta">
              {post.data.pubDate.toLocaleDateString('zh-CN')}
              {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
            </span>
            <p class="desc">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
.post-list { list-style: none; padding: 0; }
.post-list li { padding: 1.5rem 0; border-bottom: 1px solid var(--border); }
.post-list a { font-size: 1.15rem; font-weight: 600; color: var(--text); display: block; margin-bottom: 0.3rem; }
.post-list a:hover { color: var(--accent-2); }
.meta { display: block; font-size: 0.85rem; color: var(--text-muted); margin: 0.4rem 0; }
.desc { color: var(--text-muted); margin: 0.3rem 0 0; font-size: 0.95rem; }
</style>
