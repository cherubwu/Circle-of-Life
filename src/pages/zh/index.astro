---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import HeroScene from '../../components/HeroScene.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'zh'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const PANEL_COLOURS = ['#6ecfa0', '#5bbad5', '#9c88d4', '#e07bb0', '#e8a050'];
---
<html lang="zh">
<head>
  <BaseHead title="生之回环 · Circle of Life" description="面向生物科技从业者、投资人与研究者的策展 + 洞见平台，聚焦创新药与神经科学前沿。" />
</head>
<body>
  <Header />
  <HeroScene />
  <main>
    <section>
      <h2>最新文章</h2>
      <ul class="post-list">
        {posts.map((post, i) => (
          <li class="post-card">
            <span class="card-panel" style={`background:${PANEL_COLOURS[i % PANEL_COLOURS.length]}`}></span>
            <div class="card-body">
              <a href={`/Circle-of-Life/zh/blog/${post.id}/`} class="post-title">{post.data.title}</a>
              <span class="meta">
                {post.data.pubDate.toLocaleDateString('zh-CN')}
                {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
              </span>
              <p class="desc">{post.data.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
.post-list { list-style: none; padding: 0; margin: 0; }

.post-card {
  display: flex;
  border: 2px solid var(--border);
  margin-bottom: 1.2rem;
  overflow: visible;
  transition: border-color 0.2s;
}
.post-card:hover { border-color: var(--sage); }

.card-panel {
  width: 40px;
  flex-shrink: 0;
  transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.post-card:hover .card-panel { transform: translateX(-6px); }

.card-body {
  padding: 1.3rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  min-width: 0;
}

.post-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 1.08rem;
  font-weight: 500;
  letter-spacing: -0.01em;
  color: var(--light) !important;
  display: block;
}
.post-title:hover { color: var(--sage) !important; }

.meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.76rem;
  color: var(--text-muted);
  font-family: 'DM Sans', sans-serif;
}

.desc {
  color: var(--text-muted);
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.65;
}
</style>
