---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = '/Circle-of-Life';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Find paired ZH article
const allPosts = await getCollection('blog');
const pairedZh = post.data.pairSlug
  ? allPosts.find(p => p.data.pairSlug === post.data.pairSlug && p.data.lang === 'zh')
  : null;
const zhUrl = pairedZh ? `${base}/zh/blog/${pairedZh.id}/` : null;
---
<html lang="en">
<head>
  <BaseHead title={post.data.title} description={post.data.description} />
</head>
<body>
  <Header pairUrl={zhUrl ?? undefined} />
  <main>
    <article>
      <header class="article-header">
        <div class="article-meta-top">
          <span class="article-date">{dateStr}</span>
          {post.data.author && <span class="article-author"> — {post.data.author}</span>}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.tags?.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
        {post.data.description && (
          <p class="article-desc">{post.data.description}</p>
        )}
      </header>
      <div class="content">
        <Content />
      </div>
    </article>

    <nav class="post-nav">
      {prev
        ? <a href={`${base}/blog/${prev.id}/`} class="post-nav-link post-nav-prev">
            <span class="post-nav-label">← Older</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        : <span></span>
      }
      {next &&
        <a href={`${base}/blog/${next.id}/`} class="post-nav-link post-nav-next">
          <span class="post-nav-label">Newer →</span>
          <span class="post-nav-title">{next.data.title}</span>
        </a>
      }
    </nav>
  </main>
  <Footer />
</body>
</html>

<style>
.article-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 3px solid #000;
}

.article-meta-top {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.45);
  margin-bottom: 1rem;
}
.article-author { color: #E61E8D; font-weight: 600; }

.article-header h1 {
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(2rem, 4.5vw, 3.2rem);
  line-height: 1.0;
  margin: 0 0 1rem;
  color: #000;
}

.article-tags { margin-bottom: 1rem; }

.article-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  color: rgba(0,0,0,0.62);
  line-height: 1.7;
  margin: 0;
  border-left: 4px solid #F7E623;
  padding-left: 1rem;
}

.content { line-height: 1.9; }
.content h2 { margin-top: 2.8rem; }
.content p { margin: 1.2rem 0; }
.content img {
  max-width: 100%;
  border: 2.5px solid #000;
  box-shadow: 6px 6px 0 #000;
  display: block;
  margin: 2rem 0;
}

/* ── Prev / Next ── */
.post-nav {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 2px solid #000;
}
.post-nav-link {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  text-decoration: none;
  max-width: 46%;
  padding: 1rem 1.2rem;
  border: 2px solid #000;
  background: #fff;
  box-shadow: 4px 4px 0 #000;
  transition: background 0.12s, transform 0.12s, box-shadow 0.12s;
}
.post-nav-link:hover {
  background: #000;
  transform: translate(-2px, -2px);
  box-shadow: 6px 6px 0 #000;
}
.post-nav-link:hover .post-nav-label,
.post-nav-link:hover .post-nav-title { color: #F2EFE6; }
.post-nav-next { align-items: flex-end; text-align: right; }
.post-nav-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.42);
  transition: color 0.12s;
}
.post-nav-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: 0.9rem;
  color: #000;
  line-height: 1.2;
  transition: color 0.12s;
}
@media (max-width: 600px) {
  .post-nav { flex-direction: column; }
  .post-nav-link { max-width: 100%; }
  .post-nav-next { align-items: flex-start; text-align: left; }
}
</style>
