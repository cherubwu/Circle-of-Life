---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<html lang="en">
<head>
  <BaseHead title="Articles | Circle of Life" description="All articles from Circle of Life." />
</head>
<body>
  <Header />
  <main>
    <h1>Articles</h1>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{post.data.title}</a>
          <span class="meta">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
          </span>
          <p class="desc">{post.data.description}</p>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</body>
</html>

<style>
.post-list { list-style: none; padding: 0; }
.post-list li { padding: 1.5rem 0; border-bottom: 1px solid var(--border); }
.post-list a { font-size: 1.2rem; font-weight: 600; color: var(--text); }
.post-list a:hover { color: var(--accent-2); }
.meta { display: block; font-size: 0.85rem; color: var(--text-muted); margin: 0.3rem 0; }
.desc { color: var(--text-muted); margin: 0.3rem 0 0; font-size: 0.95rem; }
</style>
