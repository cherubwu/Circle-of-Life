---
const lang = Astro.currentLocale ?? 'zh';
const zhNav = { blog: '文章', about: '关于', subscribe: '订阅' };
const enNav = { blog: 'Articles', about: 'About', subscribe: 'Subscribe' };
const nav = lang === 'en' ? enNav : zhNav;
const title = lang === 'en' ? 'Circle of Life' : '生之回环';
const blogPath = lang === 'en' ? '/Circle-of-Life/en/blog' : '/Circle-of-Life/blog';
const aboutPath = lang === 'en' ? '/Circle-of-Life/en/about' : '/Circle-of-Life/about';
---
<header>
  <nav>
    <a href="/Circle-of-Life/" class="logo">
      <span class="logo-icon">🔬</span>
      <span class="logo-text">{title}</span>
    </a>
    <div class="nav-links">
      <a href={blogPath}>{nav.blog}</a>
      <a href={aboutPath}>{nav.about}</a>
      <a href="https://your-substack.substack.com" target="_blank">{nav.subscribe}</a>
      <div class="lang-toggle">
        <a href="/Circle-of-Life/" class={lang === 'zh' ? 'active' : ''}>中文</a>
        <span>|</span>
        <a href="/Circle-of-Life/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
      </div>
    </div>
  </nav>
</header>

<style>
header { border-bottom: 1px solid var(--border); padding: 1rem 2rem; background: rgba(15,15,26,0.95); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 100; }
nav { max-width: 800px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
.logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; font-size: 1.05rem; color: var(--text); text-decoration: none; }
.logo:hover { color: var(--accent-2); }
.nav-links { display: flex; align-items: center; gap: 1.5rem; }
.nav-links a { color: var(--text-muted); font-size: 0.9rem; }
.nav-links a:hover { color: var(--accent-2); }
.lang-toggle { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; border-left: 1px solid var(--border); padding-left: 1rem; }
.lang-toggle a { color: var(--text-muted); }
.lang-toggle a.active { color: var(--accent-2); font-weight: 700; pointer-events: none; }
</style>