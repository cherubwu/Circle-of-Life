---
const lang = Astro.currentLocale ?? 'en';
const nav = lang === 'zh'
  ? { blog: '文章', about: '关于', subscribe: '订阅' }
  : { blog: 'Articles', about: 'About', subscribe: 'Subscribe' };
const title = lang === 'zh' ? '生之回环' : 'Circle of Life';
const blogPath = lang === 'zh' ? '/Circle-of-Life/zh/blog' : '/Circle-of-Life/blog';
const aboutPath = lang === 'zh' ? '/Circle-of-Life/zh/about' : '/Circle-of-Life/about';
---
<header>
  <nav>
    <a href="/Circle-of-Life/" class="logo">{title}</a>
    <div class="nav-links">
      <a href={blogPath}>{nav.blog}</a>
      <a href={aboutPath}>{nav.about}</a>
      <a href="https://your-substack.substack.com" target="_blank">{nav.subscribe}</a>
      <div class="lang-toggle">
        <a href="/Circle-of-Life/" class={lang === 'en' ? 'active' : ''}>EN</a>
        <span>|</span>
        <a href="/Circle-of-Life/zh/" class={lang === 'zh' ? 'active' : ''}>中文</a>
      </div>
    </div>
  </nav>
</header>

<style>
header {
  border-bottom: 1px solid #6ecfa0;
  padding: 0.9rem 2rem;
  background: rgba(245,240,232,0.96);
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 100;
}
nav {
  max-width: 800px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.logo {
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #1a2e22;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
/* Bauhaus square logo mark */
.logo::before {
  content: '';
  display: inline-block;
  width: 10px; height: 10px;
  background: #6ecfa0;
  flex-shrink: 0;
}
.logo:hover { color: #3a5a4a; }

.nav-links {
  display: flex;
  align-items: center;
  gap: 1.8rem;
}
.nav-links a {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #4a6a5a;
  text-decoration: none;
  transition: color 0.15s;
}
.nav-links a:hover { color: #3a5a4a; }

.lang-toggle {
  display: flex;
  align-items: center;
  gap: 0;
  font-size: 0.68rem;
  border-left: 1px solid #cdc8be;
  padding-left: 1.2rem;
}
.lang-toggle span { display: none; }
.lang-toggle a {
  color: #4a6a5a;
  padding: 0.15rem 0.5rem;
  border: 1px solid transparent;
}
.lang-toggle a.active {
  color: #f5f0e8;
  background: #9c88d4;
  border-color: #9c88d4;
  font-weight: 700;
  pointer-events: none;
}
</style>
