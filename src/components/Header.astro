---
interface Props {
  pairUrl?: string; // URL of the same article in the other language
  lang?: 'en' | 'zh';
}
const { pairUrl, lang: langProp } = Astro.props;

const lang = langProp ?? (Astro.currentLocale as 'en' | 'zh') ?? 'en';
const nav = lang === 'zh'
  ? { blog: '文章', about: '关于', subscribe: '订阅' }
  : { blog: 'Articles', about: 'About', subscribe: 'Subscribe' };
const title = lang === 'zh' ? '生之回环' : 'Circle of Life';
const blogPath  = lang === 'zh' ? '/Circle-of-Life/zh/blog'  : '/Circle-of-Life/blog';
const aboutPath = lang === 'zh' ? '/Circle-of-Life/zh/about' : '/Circle-of-Life/about';

// Lang toggle targets: use paired article URL if available, otherwise homepage
const enTarget  = lang === 'zh' ? (pairUrl ?? '/Circle-of-Life/')    : null;
const zhTarget  = lang === 'en' ? (pairUrl ?? '/Circle-of-Life/zh/') : null;
---
<header>
  <nav>
    <a href="/Circle-of-Life/" class="logo">{title}</a>
    <div class="nav-links">
      <a href={blogPath}>{nav.blog}</a>
      <a href={aboutPath}>{nav.about}</a>
      <a href="https://your-substack.substack.com" target="_blank" class="nav-subscribe">{nav.subscribe}</a>
      <div class="lang-toggle">
        {lang === 'en'
          ? <span class="active">EN</span>
          : <a href={enTarget!}>EN</a>
        }
        {lang === 'zh'
          ? <span class="active">中文</span>
          : <a href={zhTarget!}>中文</a>
        }
      </div>
    </div>
  </nav>
</header>

<style>
@import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:wght@400;500;600&display=swap');

header {
  background: #F2EFE6;
  border-bottom: 3px solid #000;
  padding: 0;
}
nav {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 4vw;
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  height: 60px;
}

/* Logo */
.logo {
  font-family: 'Archivo Black', sans-serif;
  font-size: 1.1rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  padding-right: 2rem;
  border-right: 2px solid #000;
}
.logo:hover { color: #E61E8D; }

/* Nav links */
.nav-links {
  display: flex;
  align-items: stretch;
  gap: 0;
}
.nav-links a {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #000;
  text-decoration: none;
  display: flex;
  align-items: center;
  padding: 0 1.2rem;
  border-left: 1px solid rgba(0,0,0,0.12);
  transition: background 0.12s, color 0.12s;
}
.nav-links a:hover { background: #000; color: #F2EFE6; }

/* Subscribe CTA — filled */
.nav-subscribe {
  background: #E61E8D !important;
  color: #fff !important;
  font-weight: 700 !important;
  border-left: 2px solid #000 !important;
  box-shadow: 4px 0 0 #000 inset;
}
.nav-subscribe:hover { background: #000 !important; color: #E61E8D !important; }

/* Lang toggle */
.lang-toggle {
  display: flex;
  align-items: stretch;
  border-left: 2px solid #000;
}
.lang-toggle a,
.lang-toggle span {
  font-size: 0.62rem !important;
  padding: 0 0.7rem !important;
  border-left: 1px solid rgba(0,0,0,0.15) !important;
  display: flex;
  align-items: center;
  font-family: 'DM Sans', sans-serif;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}
.lang-toggle span.active {
  background: #000;
  color: #F2EFE6 !important;
  font-weight: 700;
  pointer-events: none;
}

@media (max-width: 600px) {
  .nav-links a { padding: 0 0.7rem; font-size: 0.58rem; }
  .logo { font-size: 0.9rem; padding-right: 1rem; }
}
</style>
