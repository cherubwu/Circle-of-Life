---
const lang = Astro.currentLocale ?? 'en';
const base = '/Circle-of-Life';

const headline = lang === 'zh'
  ? ['生命：', '无界。']
  : ['LIFE:', 'UNWIRED'];

const cards = lang === 'zh'
  ? [
      { title:'神经科学', sub:'脑科学 · 认知 · 神经调控', btn:'探索 →', color:'#EF5B5B', img:`${base}/organs/brain.jpg`,  href:`${base}/blog` },
      { title:'代谢系统', sub:'MASH · GLP-1 · 线粒体',   btn:'探索 →', color:'#F7E623', img:`${base}/organs/liver.jpg`,  href:`${base}/blog` },
      { title:'免疫循环', sub:'CAR-T · 免疫检查点',       btn:'探索 →', color:'#3D50B3', img:`${base}/organs/thryme.jpg`, href:`${base}/blog` },
    ]
  : [
      { title:'NEUROSCIENCE', sub:"BCI · Alzheimer's · Neuromod", btn:'DISCOVER →', color:'#EF5B5B', img:`${base}/organs/brain.jpg`,  href:`${base}/blog` },
      { title:'METABOLISM',   sub:'MASH · GLP-1 · Mitochondria',  btn:'DISCOVER →', color:'#F7E623', img:`${base}/organs/liver.jpg`,  href:`${base}/blog` },
      { title:'IMMUNOLOGY',   sub:'CAR-T · Checkpoint · Aging',   btn:'DISCOVER →', color:'#3D50B3', img:`${base}/organs/thryme.jpg`, href:`${base}/blog` },
    ];
---

<section class="bio-hero">
  <div class="bio-grid">

    <!-- Left: big headline -->
    <div class="bio-left">
      <span class="bio-eyebrow">
        {lang === 'zh' ? '— 生物创新 · 代谢 · 神经科学' : '— BIOINNOVATION · METABOLISM · NEUROSCIENCE'}
      </span>
      <h1>{headline.map(l => <>{l}<br/></>)}</h1>
      <a href="https://your-substack.substack.com" target="_blank" class="bio-cta">
        {lang === 'zh' ? '订阅周刊 →' : 'SUBSCRIBE →'}
      </a>
    </div>

    <!-- Right: floating organ illustration -->
    <div class="bio-visual">
      <!-- Yellow background slab -->
      <div class="bio-slab slab-yellow"></div>
      <!-- Pink/magenta accent slab -->
      <div class="bio-slab slab-pink"></div>
      <!-- Teal slab -->
      <div class="bio-slab slab-teal"></div>

      <!-- Floating organs -->
      <img src={`${base}/organs/digest.jpg`}  alt="Digestive system" class="organ organ-digest"  />
      <img src={`${base}/organs/brain.jpg`}   alt="Brain"            class="organ organ-brain"   />
      <img src={`${base}/organs/heart.jpg`}   alt="Heart"            class="organ organ-kidney"  />
      <img src={`${base}/organs/liver.jpg`}   alt="Liver"            class="organ organ-liver"   />

      <!-- Floating label -->
      <span class="float-label">
        {lang === 'zh' ? 'ORGANIC STRUCTURES 有机结构' : 'ORGANIC STRUCTURES'}
      </span>
    </div>

  </div>

  <!-- Card grid -->
  <div class="bio-cards">
    {cards.map(c => (
      <a href={c.href} class="bio-card" style={`--cc:${c.color}`}>
        <div class="card-visual" style={`background:${c.color}`}>
          <img src={c.img} alt={c.title} />
        </div>
        <div class="card-body">
          <h3>{c.title}</h3>
          <p>{c.sub}</p>
          <span class="card-btn">{c.btn}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:wght@400;500;600;700&display=swap');

.bio-hero {
  background: #F2EFE6;
  padding: 0 4vw 0;
  overflow: hidden;
}

/* ── 2-column grid ── */
.bio-grid {
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 4vw;
  align-items: center;
  min-height: calc(100vh - 220px);
  padding-top: 2rem;
}

/* ── Left panel ── */
.bio-left {
  display: flex;
  flex-direction: column;
  gap: 0;
  z-index: 2;
}

.bio-eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.42);
  margin-bottom: 1.2rem;
}

.bio-left h1 {
  font-family: 'Archivo Black', sans-serif;
  font-size: clamp(4.5rem, 9vw, 8rem);
  line-height: 0.85;
  text-transform: uppercase;
  color: #000;
  margin: 0 0 2.4rem;
}

.bio-cta {
  display: inline-block;
  background: #000;
  color: #F2EFE6;
  padding: 0.75rem 2rem;
  font-family: 'Archivo Black', sans-serif;
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-decoration: none;
  width: fit-content;
  box-shadow: 6px 6px 0 #E61E8D;
  transition: transform 0.15s, box-shadow 0.15s;
}
.bio-cta:hover {
  transform: translate(-3px, -3px);
  box-shadow: 9px 9px 0 #E61E8D;
  color: #F2EFE6;
  text-decoration: none;
}

/* ── Right: illustration collage ── */
.bio-visual {
  position: relative;
  height: clamp(420px, 56vh, 620px);
  z-index: 1;
}

/* Coloured background slabs */
.bio-slab {
  position: absolute;
  border-radius: 2px;
}
.slab-yellow {
  background: #F7E623;
  width: 48%;
  height: 72%;
  top: 8%;
  right: 0;
}
.slab-pink {
  background: #E61E8D;
  width: 22%;
  height: 38%;
  top: 5%;
  right: 44%;
  clip-path: polygon(0 0, 100% 8%, 90% 100%, 10% 92%);
}
.slab-teal {
  background: #1d8a78;
  width: 55%;
  height: 58%;
  bottom: 0;
  left: 0;
  clip-path: polygon(0 12%, 100% 0, 100% 100%, 0 100%);
}

/* Floating organs */
.organ {
  position: absolute;
  object-fit: contain;
  filter: drop-shadow(6px 6px 0 rgba(0,0,0,0.12));
}
.organ-digest {
  height: 68%;
  left: 8%;
  top: -4%;
  z-index: 4;
  animation: float-slow 7s ease-in-out infinite;
}
.organ-brain {
  height: 44%;
  right: 4%;
  top: 4%;
  z-index: 5;
  animation: float-slow 5s 1s ease-in-out infinite;
}
.organ-kidney {
  height: 32%;
  right: 2%;
  bottom: 6%;
  z-index: 3;
  animation: breathe 6s 0.5s ease-in-out infinite;
}
.organ-liver {
  height: 30%;
  left: 20%;
  bottom: 4%;
  z-index: 4;
  animation: breathe 8s 2s ease-in-out infinite;
}

.float-label {
  position: absolute;
  top: 8%;
  left: 44%;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.5rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(0,0,0,0.5);
  z-index: 10;
  pointer-events: none;
}
.float-label::before {
  content: '';
  display: inline-block;
  width: 14px;
  height: 1px;
  background: rgba(0,0,0,0.4);
  vertical-align: middle;
  margin-right: 0.4rem;
}

/* ── Card grid ── */
.bio-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  padding: 60px 0 64px;
}

.bio-card {
  background: #fff;
  border: 3.5px solid #000;
  text-decoration: none;
  box-shadow: 10px 10px 0 #000;
  transition: transform 0.15s, box-shadow 0.15s;
  display: flex;
  flex-direction: column;
}
.bio-card:hover {
  transform: translate(-4px, -4px);
  box-shadow: 14px 14px 0 #000;
}

.card-visual {
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-bottom: 3px solid #000;
}
.card-visual img {
  max-height: 82%;
  max-width: 82%;
  object-fit: contain;
  filter: drop-shadow(3px 3px 0 rgba(0,0,0,0.15));
  transition: transform 0.25s;
}
.bio-card:hover .card-visual img {
  transform: scale(1.06) translateY(-4px);
}

.card-body {
  padding: 1.2rem 1.4rem 1.6rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.card-body h3 {
  font-family: 'Archivo Black', sans-serif;
  font-size: 1rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #000;
  margin: 0;
}
.card-body p {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: rgba(0,0,0,0.5);
  margin: 0;
  line-height: 1.5;
}
.card-btn {
  margin-top: 0.8rem;
  display: inline-block;
  background: var(--cc);
  border: 2.5px solid #000;
  padding: 0.5rem 1rem;
  font-family: 'Archivo Black', sans-serif;
  font-size: 0.7rem;
  color: #000;
  box-shadow: 4px 4px 0 #000;
  width: fit-content;
  letter-spacing: 0.05em;
}

/* ── Animations ── */
@keyframes float-slow {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50%       { transform: translateY(-18px) rotate(1deg); }
}
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.05); }
}

/* ── Responsive ── */
@media (max-width: 780px) {
  .bio-grid { grid-template-columns: 1fr; min-height: auto; }
  .bio-visual { height: 320px; }
  .bio-left h1 { font-size: 4rem; }
  .bio-cards { grid-template-columns: 1fr; }
}
</style>
