---
const lang = Astro.currentLocale ?? 'en';
const base = '/Circle-of-Life';
---

<section class="hero-scene" id="hero-scene">
  <!-- Surrealist ghost circle — large semi-transparent form in the BG -->
  <div class="ghost-circle" aria-hidden="true"></div>
  <!-- Morphing organic blob -->
  <div class="morph-blob" aria-hidden="true"></div>

  <canvas id="neural-canvas"></canvas>

  <div class="scene-left">
    <span class="badge">Biotech · Neuroscience · 2025</span>
    <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
    <p class="tagline">{lang === 'zh'
      ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
      : 'Biotech insights from inside the lab.\nInnovative drugs · Neuroscience · Metabolism.'}</p>
    <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
      {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
    </a>
    <p class="graph-hint">{lang === 'zh' ? '→ 拖拽行星 · 悬停查看 · 点击文章' : '→ Drag planets · Hover to reveal · Click for articles'}</p>
  </div>
</section>

<script define:vars={{ lang, base }}>
const canvas = document.getElementById('neural-canvas');
const ctx = canvas.getContext('2d');
let W = 0, H = 0;
let t = 0;

/* ── Mouse / comet ── */
const mouse = { x: -9999, y: -9999, down: false };
const cometTrail = [];
const TRAIL_LEN = 28;

function onMouseMove(e) {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  cometTrail.unshift({ x: mouse.x, y: mouse.y });
  if (cometTrail.length > TRAIL_LEN) cometTrail.pop();
}
window.addEventListener('mousemove', onMouseMove);

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  initKGPositions();
}
window.addEventListener('resize', resize);

/* ── Knowledge graph data ── */
const KG_NODES = [
  { id: 'metabolism', label: lang === 'zh' ? '代谢' : 'Metabolism',    color: '#4A7C59', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuro',      label: lang === 'zh' ? '脑科学' : 'Neuroscience', color: '#2B5C8A', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'immune',     label: lang === 'zh' ? '免疫' : 'Immunology',     color: '#C4602B', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'mash',     label: 'MASH/MASLD',  color: '#6BAA7A', r: 19, url: `${base}/blog/mash-pipeline-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'glp1',     label: 'GLP-1',        color: '#6BAA7A', r: 17, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'lipid',    label: lang==='zh'?'脂质':'Lipid',        color: '#8DBF9A', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'insulin',  label: lang==='zh'?'胰岛素':'Insulin',    color: '#8DBF9A', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'mito',     label: lang==='zh'?'线粒体':'Mitochondria',color: '#8DBF9A', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'bci',       label: 'BCI',           color: '#4A7FAA', r: 19, url: `${base}/blog/BCI-future-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'alzheimer', label: "Alzheimer's",   color: '#4A7FAA', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'parkinson', label: "Parkinson's",   color: '#6E9DC0', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuromod',  label: lang==='zh'?'神经调控':'Neuromod', color: '#6E9DC0', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'cart',       label: 'CAR-T',          color: '#D4531A', r: 17, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'checkpoint', label: lang==='zh'?'检查点':'Checkpoint', color: '#D4531A', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'autoimmune', label: lang==='zh'?'自身免疫':'Autoimmune',color: '#E8A020', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'senescence', label: lang==='zh'?'衰老':'Senescence',   color: '#E8A020', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
];

const KG_LINKS = [
  ['metabolism','mash'],['metabolism','glp1'],['metabolism','lipid'],
  ['metabolism','insulin'],['metabolism','mito'],
  ['neuro','bci'],['neuro','alzheimer'],['neuro','parkinson'],['neuro','neuromod'],
  ['immune','cart'],['immune','checkpoint'],['immune','autoimmune'],['immune','senescence'],
  ['glp1','mash'],['senescence','mito'],['insulin','alzheimer'],
];

const nodeMap = Object.fromEntries(KG_NODES.map(n => [n.id, n]));

/* ── Pre-compute per-node wobbly blob points (fixed, no per-frame jitter) ── */
KG_NODES.forEach(n => {
  const pts = 10;
  n.wpts = Array.from({ length: pts }, (_, i) => ({
    angle: (i / pts) * Math.PI * 2 + (Math.random() - 0.5) * 0.3,
    rf: 1 + (Math.random() - 0.5) * 0.22,
  }));
});

function initKGPositions() {
  const cx = W * 0.65, cy = H * 0.5;
  const roots = KG_NODES.filter(n => n.type === 'root');
  roots.forEach((r, i) => {
    const angle = (i / roots.length) * Math.PI * 2 - Math.PI / 2;
    r.x = cx + Math.cos(angle) * Math.min(W, H) * 0.17;
    r.y = cy + Math.sin(angle) * Math.min(W, H) * 0.17;
  });
  KG_NODES.filter(n => n.type === 'leaf').forEach((n, i) => {
    n.x = cx + (Math.random() - 0.5) * W * 0.48;
    n.y = cy + (Math.random() - 0.5) * H * 0.7;
  });
}

/* ── Force simulation ── */
function tickForce() {
  const alpha = 0.06;
  // Link forces
  for (const [sid, tid] of KG_LINKS) {
    const s = nodeMap[sid], t2 = nodeMap[tid];
    if (!s || !t2) continue;
    const ideal = (s.type==='root'||t2.type==='root') ? 155 : 105;
    const dx = t2.x - s.x, dy = t2.y - s.y;
    const dist = Math.sqrt(dx*dx+dy*dy) || 1;
    const f = (dist - ideal) / dist * alpha * 0.5;
    if (!s.fx) { s.vx += dx*f; s.vy += dy*f; }
    if (!t2.fx) { t2.vx -= dx*f; t2.vy -= dy*f; }
  }
  // Repulsion
  for (let i = 0; i < KG_NODES.length; i++) {
    for (let j = i+1; j < KG_NODES.length; j++) {
      const a = KG_NODES[i], b = KG_NODES[j];
      const dx = b.x-a.x, dy = b.y-a.y;
      const dist = Math.sqrt(dx*dx+dy*dy) || 1;
      const minDist = a.r + b.r + 50;
      if (dist < minDist) {
        const f = (minDist - dist) / dist * 0.4;
        if (!a.fx) { a.vx -= dx*f; a.vy -= dy*f; }
        if (!b.fx) { b.vx += dx*f; b.vy += dy*f; }
      }
    }
  }
  // Center pull (right half)
  const cx = W*0.65, cy = H*0.5;
  KG_NODES.forEach(n => {
    if (n.fx !== null) { n.x = n.fx; n.y = n.fy; return; }
    n.vx += (cx - n.x) * 0.002;
    n.vy += (cy - n.y) * 0.002;
    n.vx *= 0.85; n.vy *= 0.85;
    n.x += n.vx; n.y += n.vy;
    // Keep in right half
    n.x = Math.max(W*0.46 + n.r, Math.min(W - n.r - 4, n.x));
    n.y = Math.max(n.r + 4, Math.min(H - n.r - 4, n.y));
  });
}

/* ── Drag ── */
let dragging = null;

canvas.addEventListener('mousedown', e => {
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2) { dragging = n; n.fx = n.x; n.fy = n.y; break; }
  }
});

canvas.addEventListener('mousemove', e => {
  if (dragging) { dragging.fx = mouse.x; dragging.fy = mouse.y; }
});

canvas.addEventListener('mouseup', e => {
  if (dragging) { dragging.fx = null; dragging.fy = null; dragging = null; }
});

canvas.addEventListener('click', e => {
  if (dragging) return;
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2 && n.url) { window.location.href = n.url; break; }
  }
});

/* ── Hover detection ── */
let hoveredNode = null;
canvas.addEventListener('mousemove', () => {
  if (dragging) { canvas.style.cursor = 'grabbing'; return; }
  hoveredNode = null;
  for (const n of KG_NODES) {
    const dx = mouse.x-n.x, dy = mouse.y-n.y;
    if (dx*dx+dy*dy < (n.r+8)**2) { hoveredNode = n; break; }
  }
  canvas.style.cursor = hoveredNode ? (hoveredNode.url ? 'pointer' : 'grab') : 'none';
});

/* ── Background geometric shapes (Bauhaus / Surrealist floating forms) ── */
const SHAPE_COLS = [
  'rgba(110,207,160,', // sage
  'rgba(91,186,213,',  // teal
  'rgba(156,136,212,', // lavender
  'rgba(224,123,176,', // rose
  'rgba(232,160,80,',  // amber
];
const SHAPE_TYPES = ['circle', 'triangle', 'rect', 'circle', 'circle'];
const BG_SHAPES = Array.from({ length: 28 }, () => ({
  x: Math.random(), y: Math.random(),
  vx: (Math.random()-0.5)*0.00007, vy: (Math.random()-0.5)*0.00007,
  size: 12 + Math.random() * 40,
  rot: Math.random() * Math.PI * 2,
  rotV: (Math.random()-0.5) * 0.004,
  type: SHAPE_TYPES[Math.floor(Math.random()*SHAPE_TYPES.length)],
  col: SHAPE_COLS[Math.floor(Math.random()*SHAPE_COLS.length)],
  alpha: 0.04 + Math.random() * 0.07,
  hollow: Math.random() > 0.4,
}));

/* ── Signals ── */
const signals = [];
function spawnSignal() {
  const link = KG_LINKS[Math.floor(Math.random()*KG_LINKS.length)];
  const s = nodeMap[link[0]], t2 = nodeMap[link[1]];
  if (s && t2) signals.push({ s, t2, progress: 0, speed: 0.006+Math.random()*0.007 });
}
setInterval(spawnSignal, 350);

/* ── Colour helpers ── */
function hexToRgb(hex) {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}
function darken(hex, amt) {
  const [r,g,b] = hexToRgb(hex);
  return `rgb(${Math.max(0,r-amt)},${Math.max(0,g-amt)},${Math.max(0,b-amt)})`;
}

/* ── Wobbly blob path (hand-drawn feel) ── */
function wobblyPath(cx, cy, r, wpts) {
  const pts = wpts.map(p => ({
    x: cx + Math.cos(p.angle) * r * p.rf,
    y: cy + Math.sin(p.angle) * r * p.rf,
  }));
  ctx.beginPath();
  ctx.moveTo((pts[0].x + pts[pts.length-1].x)/2, (pts[0].y + pts[pts.length-1].y)/2);
  for (let i = 0; i < pts.length; i++) {
    const a = pts[i], b = pts[(i+1) % pts.length];
    ctx.quadraticCurveTo(a.x, a.y, (a.x+b.x)/2, (a.y+b.y)/2);
  }
  ctx.closePath();
}

/* ── Draw node — Mid-Century Modern style ── */
function drawPlanet(n) {
  const isHov = n === hoveredNode;
  const isDrag = n === dragging;
  const bob = isDrag ? 0 : Math.sin(t * 1.4 + n.x * 0.007) * 2.5;
  const scale = isDrag ? 1.1 : (isHov ? 1.07 : 1);
  const r = n.r * scale;
  const cx = n.x, cy = n.y + bob;
  const INK = '#1a1a2e';

  if (n.type === 'root') {
    /* ── Atomic orbital root node ── */
    // Dashed orbital ring
    ctx.beginPath(); ctx.arc(cx, cy, r * 1.75, 0, Math.PI * 2);
    ctx.strokeStyle = n.color + '55'; ctx.lineWidth = 1.2;
    ctx.setLineDash([5, 6]); ctx.stroke(); ctx.setLineDash([]);

    // Radiating spokes
    const spokes = 8;
    for (let i = 0; i < spokes; i++) {
      const a = (i / spokes) * Math.PI * 2 + t * 0.12;
      ctx.beginPath();
      ctx.moveTo(cx + Math.cos(a) * r * 1.02, cy + Math.sin(a) * r * 1.02);
      ctx.lineTo(cx + Math.cos(a) * r * 1.68, cy + Math.sin(a) * r * 1.68);
      ctx.strokeStyle = n.color + '44'; ctx.lineWidth = 1; ctx.stroke();
    }

    // Main flat circle
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fillStyle = n.color; ctx.fill();

    // Clipped highlight + shadow
    ctx.save(); ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2); ctx.clip();
    ctx.fillStyle = 'rgba(0,0,0,0.2)';
    ctx.beginPath(); ctx.arc(cx + r*0.3, cy + r*0.35, r, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.42)';
    ctx.beginPath(); ctx.arc(cx - r*0.28, cy - r*0.25, r*0.38, 0, Math.PI*2); ctx.fill();
    ctx.restore();

    // Bold ink outline
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2);
    ctx.strokeStyle = INK; ctx.lineWidth = 3.5; ctx.stroke();

    // Centre dot (atomic nucleus)
    ctx.beginPath(); ctx.arc(cx, cy, r * 0.2, 0, Math.PI*2);
    ctx.fillStyle = INK; ctx.fill();

  } else {
    /* ── Biomorphic leaf node ── */
    function shape() { wobblyPath(cx, cy, r, n.wpts); }

    shape(); ctx.fillStyle = n.color; ctx.fill();

    ctx.save(); shape(); ctx.clip();
    ctx.fillStyle = 'rgba(0,0,0,0.2)';
    ctx.beginPath(); ctx.arc(cx + r*0.28, cy + r*0.32, r*0.92, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.beginPath(); ctx.arc(cx - r*0.27, cy - r*0.25, r*0.35, 0, Math.PI*2); ctx.fill();
    ctx.restore();

    shape(); ctx.strokeStyle = INK; ctx.lineWidth = 2.5; ctx.lineJoin = 'round'; ctx.stroke();
  }

  // Hover pulse ring
  if (isHov || isDrag) {
    ctx.beginPath(); ctx.arc(cx, cy, r + (n.type==='root' ? r*0.75+6 : 6) + Math.sin(t*4)*2, 0, Math.PI*2);
    ctx.strokeStyle = n.color + 'bb'; ctx.lineWidth = 2.5;
    ctx.setLineDash([5,3]); ctx.stroke(); ctx.setLineDash([]);
  }

  // URL dot — small terracotta circle
  if (n.url) {
    ctx.beginPath(); ctx.arc(cx + r*0.72, cy - r*0.72, 5, 0, Math.PI*2);
    ctx.fillStyle = isHov ? '#F5EED8' : '#D4531A';
    ctx.strokeStyle = INK; ctx.lineWidth = 1.8; ctx.fill(); ctx.stroke();
  }

  // Label on hover/drag — Bauhaus flat rect
  if (isHov || isDrag) {
    const label = n.url ? `${n.label} →` : n.label;
    const fSize = Math.max(10, n.r * 0.75);
    ctx.font = `700 ${fSize}px 'DM Sans', sans-serif`;
    const tw = ctx.measureText(label).width;
    const lx = cx;
    const ly = cy - (n.type === 'root' ? r*1.75 + r + 10 : r + 14);
    // Flat rect background (Bauhaus — no border-radius)
    ctx.fillStyle = n.color;
    ctx.fillRect(lx - tw/2 - 10, ly - fSize/2 - 5, tw + 20, fSize + 10);
    ctx.strokeStyle = INK; ctx.lineWidth = 2;
    ctx.strokeRect(lx - tw/2 - 10, ly - fSize/2 - 5, tw + 20, fSize + 10);
    ctx.fillStyle = '#F5EED8';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(label, lx, ly);
  }
}

/* ── Draw comet ── */
function drawComet() {
  if (cometTrail.length < 2) return;
  for (let i = 1; i < cometTrail.length; i++) {
    const ratio = 1 - i/cometTrail.length;
    const a = cometTrail[i-1], b = cometTrail[i];
    ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
    ctx.strokeStyle = `rgba(110,207,160,${ratio*0.6})`;
    ctx.lineWidth = ratio*3; ctx.lineCap = 'round'; ctx.stroke();
  }
  // Flat head — no gradient, Bauhaus solid dot
  ctx.beginPath(); ctx.arc(mouse.x,mouse.y,7,0,Math.PI*2);
  ctx.fillStyle = '#6ecfa0'; ctx.fill();
  ctx.strokeStyle = '#1a1a2e'; ctx.lineWidth = 2; ctx.stroke();
  ctx.beginPath(); ctx.arc(mouse.x,mouse.y,2.5,0,Math.PI*2);
  ctx.fillStyle = '#f5f0e8'; ctx.fill();
}

/* ── Main loop ── */
function animate() {
  t += 0.014;
  ctx.clearRect(0, 0, W, H);

  // BG — warm dark (not cool purple-black)
  ctx.fillStyle = '#1a1a2e'; ctx.fillRect(0,0,W,H);

  // Floating Bauhaus / Surrealist geometric shapes
  BG_SHAPES.forEach(s => {
    s.x += s.vx; s.y += s.vy; s.rot += s.rotV;
    if(s.x < -0.05) s.x = 1.05; if(s.x > 1.05) s.x = -0.05;
    if(s.y < -0.05) s.y = 1.05; if(s.y > 1.05) s.y = -0.05;
    const px = s.x*W, py = s.y*H;
    ctx.save(); ctx.translate(px, py); ctx.rotate(s.rot);
    const fill = s.col + s.alpha + ')';
    const stroke = s.col + (s.alpha * 1.8) + ')';
    ctx.strokeStyle = stroke; ctx.lineWidth = 1.5;
    if (s.type === 'circle') {
      ctx.beginPath(); ctx.arc(0, 0, s.size, 0, Math.PI*2);
      if (s.hollow) { ctx.stroke(); } else { ctx.fillStyle = fill; ctx.fill(); }
    } else if (s.type === 'triangle') {
      ctx.beginPath();
      ctx.moveTo(0, -s.size); ctx.lineTo(s.size*0.866, s.size*0.5); ctx.lineTo(-s.size*0.866, s.size*0.5);
      ctx.closePath();
      if (s.hollow) { ctx.stroke(); } else { ctx.fillStyle = fill; ctx.fill(); }
    } else {
      if (s.hollow) { ctx.strokeRect(-s.size/2, -s.size/2, s.size, s.size); }
      else { ctx.fillStyle = fill; ctx.fillRect(-s.size/2, -s.size/2, s.size, s.size); }
    }
    ctx.restore();
  });

  // Force tick
  tickForce();

  // KG links — curved arcs (Mid-Century organic flow)
  for (const [sid,tid] of KG_LINKS) {
    const s=nodeMap[sid],t2=nodeMap[tid]; if(!s||!t2) continue;
    const mx=(s.x+t2.x)/2, my=(s.y+t2.y)/2;
    const dx=t2.x-s.x, dy=t2.y-s.y, len=Math.sqrt(dx*dx+dy*dy)||1;
    const bend = 28;
    const cpx=mx-(dy/len)*bend, cpy=my+(dx/len)*bend;
    // shadow
    ctx.beginPath(); ctx.moveTo(s.x,s.y+2); ctx.quadraticCurveTo(cpx,cpy+2,t2.x,t2.y+2);
    ctx.strokeStyle='rgba(0,0,0,0.3)'; ctx.lineWidth=3.5; ctx.lineCap='round'; ctx.stroke();
    // coloured curve
    const [rr,gg,bb]=hexToRgb(s.color);
    ctx.beginPath(); ctx.moveTo(s.x,s.y); ctx.quadraticCurveTo(cpx,cpy,t2.x,t2.y);
    ctx.strokeStyle=`rgba(${rr},${gg},${bb},0.5)`; ctx.lineWidth=2.5; ctx.stroke();
  }

  // Signals on KG links — flat dot, no gradient
  for(let i=signals.length-1;i>=0;i--){
    const sig=signals[i]; sig.progress+=sig.speed;
    if(sig.progress>=1){signals.splice(i,1);continue;}
    const sx=sig.s.x+(sig.t2.x-sig.s.x)*sig.progress;
    const sy=sig.s.y+(sig.t2.y-sig.s.y)*sig.progress;
    ctx.beginPath(); ctx.arc(sx,sy,4,0,Math.PI*2);
    ctx.fillStyle=sig.s.color; ctx.fill();
    ctx.strokeStyle='#0c0820'; ctx.lineWidth=1.5; ctx.stroke();
  }

  // Divider — warm ink tone
  ctx.beginPath(); ctx.moveTo(W*0.47,H*0.1); ctx.lineTo(W*0.47,H*0.9);
  ctx.strokeStyle='rgba(212,83,26,0.2)'; ctx.lineWidth=1;
  ctx.setLineDash([3,12]); ctx.stroke(); ctx.setLineDash([]);

  // Planets (KG nodes)
  KG_NODES.forEach(n => drawPlanet(n));

  // Comet on top
  drawComet();

  requestAnimationFrame(animate);
}

resize();
requestAnimationFrame(animate);
</script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700&display=swap');

.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
  cursor: none;
}

#neural-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-left {
