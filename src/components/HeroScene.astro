---
import KnowledgeGraph from './KnowledgeGraph.astro';
const lang = Astro.currentLocale ?? 'en';
---

<section class="hero-scene" id="hero-scene">
  <!-- Neural network animated background -->
  <canvas id="neural-canvas"></canvas>

  <div class="scene-layout">
    <!-- Left: text -->
    <div class="scene-left">
      <span class="badge">Biotech · Neuroscience · 2025</span>
      <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
      <p class="tagline">{lang === 'zh'
        ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
        : 'Biotech insights from inside the lab.\nInnovative drugs · Neuroscience · Metabolism.'}</p>
      <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
        {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
      </a>
      <div class="stats">
        <div class="stat"><span class="stat-n">7+</span><span class="stat-l">{lang === 'zh' ? '研究领域' : 'Research Areas'}</span></div>
        <div class="stat"><span class="stat-n">Weekly</span><span class="stat-l">{lang === 'zh' ? '内容更新' : 'Updates'}</span></div>
        <div class="stat"><span class="stat-n">2025</span><span class="stat-l">{lang === 'zh' ? '最新前沿' : 'Cutting Edge'}</span></div>
      </div>
    </div>

    <!-- Right: knowledge graph -->
    <div class="scene-right">
      <div class="graph-panel">
        <KnowledgeGraph />
      </div>
    </div>
  </div>
</section>

<script>
const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
let W = 0, H = 0;
const mouse = { x: -9999, y: -9999 };
let t = 0;

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
}
resize();
window.addEventListener('resize', resize);
window.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
});

/* ── Neural nodes ── */
const NODE_COUNT = 60;
type Node = { x: number; y: number; vx: number; vy: number; r: number; pulse: number; pulseSpeed: number; col: string };
const COLS = ['rgba(167,139,250,', 'rgba(6,182,212,', 'rgba(16,185,129,', 'rgba(245,158,11,'];

const nodes: Node[] = Array.from({ length: NODE_COUNT }, () => ({
  x: Math.random() * 1,
  y: Math.random() * 1,
  vx: (Math.random() - 0.5) * 0.00015,
  vy: (Math.random() - 0.5) * 0.00015,
  r: Math.random() * 2.5 + 1,
  pulse: Math.random() * Math.PI * 2,
  pulseSpeed: 0.02 + Math.random() * 0.03,
  col: COLS[Math.floor(Math.random() * COLS.length)],
}));

/* ── Signal packets traveling along edges ── */
type Signal = { from: number; to: number; progress: number; speed: number; col: string };
const signals: Signal[] = [];
function spawnSignal() {
  const from = Math.floor(Math.random() * NODE_COUNT);
  const to = Math.floor(Math.random() * NODE_COUNT);
  if (from === to) return;
  signals.push({ from, to, progress: 0, speed: 0.004 + Math.random() * 0.006, col: COLS[Math.floor(Math.random() * COLS.length)] });
}
setInterval(spawnSignal, 400);

function animate() {
  t += 0.012;
  ctx.clearRect(0, 0, W, H);

  // Background
  const bg = ctx.createLinearGradient(0, 0, W * 0.7, H);
  bg.addColorStop(0, '#06060f');
  bg.addColorStop(0.5, '#0a0a1a');
  bg.addColorStop(1, '#080810');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Ambient glow blobs
  const blobs = [
    { x: W * 0.18, y: H * 0.35, r: 280, col: 'rgba(124,58,237,0.055)' },
    { x: W * 0.55, y: H * 0.6,  r: 220, col: 'rgba(6,182,212,0.04)' },
    { x: W * 0.82, y: H * 0.3,  r: 200, col: 'rgba(16,185,129,0.035)' },
  ];
  blobs.forEach(b => {
    const g = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
    g.addColorStop(0, b.col);
    g.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, W, H);
  });

  // Update nodes
  nodes.forEach(n => {
    n.x += n.vx;
    n.y += n.vy;
    if (n.x < 0 || n.x > 1) n.vx *= -1;
    if (n.y < 0 || n.y > 1) n.vy *= -1;
    n.pulse += n.pulseSpeed;

    // Mouse attraction
    const px = n.x * W, py = n.y * H;
    const dx = mouse.x - px, dy = mouse.y - py;
    const dist = Math.sqrt(dx*dx + dy*dy);
    if (dist < 200 && dist > 0) {
      n.vx += (dx / dist) * 0.00004;
      n.vy += (dy / dist) * 0.00004;
    }
    // Speed cap
    const speed = Math.sqrt(n.vx*n.vx + n.vy*n.vy);
    if (speed > 0.0003) { n.vx *= 0.0003/speed; n.vy *= 0.0003/speed; }
  });

  // Draw edges
  const CONNECT_DIST = Math.min(W, H) * 0.22;
  for (let i = 0; i < NODE_COUNT; i++) {
    for (let j = i + 1; j < NODE_COUNT; j++) {
      const a = nodes[i], b = nodes[j];
      const dx = (a.x - b.x) * W, dy = (a.y - b.y) * H;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < CONNECT_DIST) {
        const alpha = (1 - dist / CONNECT_DIST) * 0.18;
        ctx.beginPath();
        ctx.moveTo(a.x * W, a.y * H);
        ctx.lineTo(b.x * W, b.y * H);
        ctx.strokeStyle = `rgba(167,139,250,${alpha})`;
        ctx.lineWidth = 0.6;
        ctx.stroke();
      }
    }
  }

  // Draw signals
  for (let i = signals.length - 1; i >= 0; i--) {
    const s = signals[i];
    s.progress += s.speed;
    if (s.progress >= 1) { signals.splice(i, 1); continue; }
    const from = nodes[s.from], to = nodes[s.to];
    const sx = from.x * W + (to.x * W - from.x * W) * s.progress;
    const sy = from.y * H + (to.y * H - from.y * H) * s.progress;
    const trail = 0.08;
    const tx = from.x * W + (to.x * W - from.x * W) * Math.max(0, s.progress - trail);
    const ty = from.y * H + (to.y * H - from.y * H) * Math.max(0, s.progress - trail);

    const grad = ctx.createLinearGradient(tx, ty, sx, sy);
    grad.addColorStop(0, s.col + '0)');
    grad.addColorStop(1, s.col + '0.9)');
    ctx.beginPath();
    ctx.moveTo(tx, ty);
    ctx.lineTo(sx, sy);
    ctx.strokeStyle = grad;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Head dot
    ctx.beginPath();
    ctx.arc(sx, sy, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = s.col + '1)';
    ctx.fill();
  }

  // Draw nodes
  nodes.forEach(n => {
    const px = n.x * W, py = n.y * H;
    const pulseMult = 1 + Math.sin(n.pulse) * 0.3;
    const r = n.r * pulseMult;

    // Glow
    const g = ctx.createRadialGradient(px, py, 0, px, py, r * 4);
    g.addColorStop(0, n.col + '0.3)');
    g.addColorStop(1, n.col + '0)');
    ctx.beginPath();
    ctx.arc(px, py, r * 4, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();

    // Core
    ctx.beginPath();
    ctx.arc(px, py, r, 0, Math.PI * 2);
    ctx.fillStyle = n.col + `${0.6 + Math.sin(n.pulse) * 0.3})`;
    ctx.fill();
  });

  requestAnimationFrame(animate);
}
requestAnimationFrame(animate);
</script>

<style>
.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
}

#neural-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-layout {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  height: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 3rem;
  gap: 3rem;
}

/* ─── Left ─── */
.scene-left {
  flex: 0 0 48%;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.badge {
  display: inline-block;
  font-size: 0.62rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #67e8f9;
  border: 1px solid rgba(103,232,249,0.35);
  padding: 0.25rem 0.9rem;
  border-radius: 999px;
  margin-bottom: 1.4rem;
  background: rgba(6,182,212,0.07);
  width: fit-content;
}

.scene-left h1 {
  font-size: clamp(3rem, 5.5vw, 5.2rem);
  line-height: 0.95;
  margin: 0 0 1.4rem;
  background: linear-gradient(135deg, #f8fafc 0%, #c4b5fd 50%, #67e8f9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.tagline {
  color: rgba(200,195,230,0.8);
  font-size: 0.9rem;
  line-height: 1.75;
  margin: 0 0 2rem;
  white-space: pre-line;
  max-width: 380px;
}

.hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  color: white;
  padding: 0.75rem 2rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.88rem;
  box-shadow: 0 0 28px rgba(124,58,237,0.5);
  width: fit-content;
  margin-bottom: 2.5rem;
  transition: transform 0.2s, box-shadow 0.2s;
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 40px rgba(124,58,237,0.7);
  color: white;
  text-decoration: none;
}

.stats {
  display: flex;
  gap: 2rem;
}
.stat {
  display: flex;
  flex-direction: column;
}
.stat-n {
  font-size: 1.1rem;
  font-weight: 700;
  color: #a78bfa;
  font-family: monospace;
}
.stat-l {
  font-size: 0.72rem;
  color: rgba(148,163,184,0.75);
  margin-top: 0.15rem;
}

/* ─── Right ─── */
.scene-right {
  flex: 1;
  display: flex;
  align-items: center;
}

.graph-panel {
  width: 100%;
  background: rgba(10,8,24,0.6);
  border: 1px solid rgba(45,45,78,0.8);
  border-radius: 20px;
  padding: 1.2rem 1.4rem;
  backdrop-filter: blur(16px);
  box-shadow: 0 0 40px rgba(124,58,237,0.08), inset 0 0 0 1px rgba(167,139,250,0.06);
}

.graph-panel :global(.kg-wrapper) { margin: 0; }
.graph-panel :global(.kg-title) { font-size: 1rem; }

@media (max-width: 900px) {
  .scene-layout { flex-direction: column; height: auto; padding: 5rem 1.5rem 2rem; gap: 2rem; }
  .scene-left { flex: none; }
  .scene-right { width: 100%; }
}
</style>
