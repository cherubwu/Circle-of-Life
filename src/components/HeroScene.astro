---
const lang = Astro.currentLocale ?? 'en';
const base = '/Circle-of-Life';
---

<section class="hero-scene" id="hero-scene">
  <canvas id="neural-canvas"></canvas>

  <div class="scene-left">
    <span class="badge">Biotech · Neuroscience · 2025</span>
    <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
    <p class="tagline">{lang === 'zh'
      ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
      : 'Biotech insights from inside the lab.\nInnovative drugs · Neuroscience · Metabolism.'}</p>
    <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
      {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
    </a>
    <p class="graph-hint">{lang === 'zh' ? '→ 拖拽行星 · 悬停查看 · 点击文章' : '→ Drag planets · Hover to reveal · Click for articles'}</p>
  </div>
</section>

<script define:vars={{ lang, base }}>
const canvas = document.getElementById('neural-canvas');
const ctx = canvas.getContext('2d');
let W = 0, H = 0;
let t = 0;

/* ── Mouse / comet ── */
const mouse = { x: -9999, y: -9999, down: false };
const cometTrail = [];
const TRAIL_LEN = 28;

function onMouseMove(e) {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  cometTrail.unshift({ x: mouse.x, y: mouse.y });
  if (cometTrail.length > TRAIL_LEN) cometTrail.pop();
}
window.addEventListener('mousemove', onMouseMove);

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  initKGPositions();
}
window.addEventListener('resize', resize);

/* ── Knowledge graph data ── */
const KG_NODES = [
  { id: 'metabolism', label: lang === 'zh' ? '代谢' : 'Metabolism',    color: '#00d48a', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuro',      label: lang === 'zh' ? '脑科学' : 'Neuroscience', color: '#7c6cff', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'immune',     label: lang === 'zh' ? '免疫' : 'Immunology',     color: '#ffb800', r: 30, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'mash',     label: 'MASH/MASLD',  color: '#00e5a0', r: 19, url: `${base}/blog/mash-pipeline-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'glp1',     label: 'GLP-1',        color: '#00e5a0', r: 17, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'lipid',    label: lang==='zh'?'脂质':'Lipid',        color: '#00e5a0', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'insulin',  label: lang==='zh'?'胰岛素':'Insulin',    color: '#00e5a0', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'mito',     label: lang==='zh'?'线粒体':'Mitochondria',color: '#00e5a0', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'bci',       label: 'BCI',           color: '#b09eff', r: 19, url: `${base}/blog/BCI-future-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'alzheimer', label: "Alzheimer's",   color: '#b09eff', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'parkinson', label: "Parkinson's",   color: '#b09eff', r: 15, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuromod',  label: lang==='zh'?'神经调控':'Neuromod', color: '#b09eff', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  { id: 'cart',       label: 'CAR-T',          color: '#ffce00', r: 17, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'checkpoint', label: lang==='zh'?'检查点':'Checkpoint', color: '#ffce00', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'autoimmune', label: lang==='zh'?'自身免疫':'Autoimmune',color: '#ffce00', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'senescence', label: lang==='zh'?'衰老':'Senescence',   color: '#ffce00', r: 14, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
];

const KG_LINKS = [
  ['metabolism','mash'],['metabolism','glp1'],['metabolism','lipid'],
  ['metabolism','insulin'],['metabolism','mito'],
  ['neuro','bci'],['neuro','alzheimer'],['neuro','parkinson'],['neuro','neuromod'],
  ['immune','cart'],['immune','checkpoint'],['immune','autoimmune'],['immune','senescence'],
  ['glp1','mash'],['senescence','mito'],['insulin','alzheimer'],
];

const nodeMap = Object.fromEntries(KG_NODES.map(n => [n.id, n]));

/* ── Pre-compute per-node wobbly blob points (fixed, no per-frame jitter) ── */
KG_NODES.forEach(n => {
  const pts = 10;
  n.wpts = Array.from({ length: pts }, (_, i) => ({
    angle: (i / pts) * Math.PI * 2 + (Math.random() - 0.5) * 0.3,
    rf: 1 + (Math.random() - 0.5) * 0.22,
  }));
});

function initKGPositions() {
  const cx = W * 0.65, cy = H * 0.5;
  const roots = KG_NODES.filter(n => n.type === 'root');
  roots.forEach((r, i) => {
    const angle = (i / roots.length) * Math.PI * 2 - Math.PI / 2;
    r.x = cx + Math.cos(angle) * Math.min(W, H) * 0.17;
    r.y = cy + Math.sin(angle) * Math.min(W, H) * 0.17;
  });
  KG_NODES.filter(n => n.type === 'leaf').forEach((n, i) => {
    n.x = cx + (Math.random() - 0.5) * W * 0.48;
    n.y = cy + (Math.random() - 0.5) * H * 0.7;
  });
}

/* ── Force simulation ── */
function tickForce() {
  const alpha = 0.06;
  // Link forces
  for (const [sid, tid] of KG_LINKS) {
    const s = nodeMap[sid], t2 = nodeMap[tid];
    if (!s || !t2) continue;
    const ideal = (s.type==='root'||t2.type==='root') ? 155 : 105;
    const dx = t2.x - s.x, dy = t2.y - s.y;
    const dist = Math.sqrt(dx*dx+dy*dy) || 1;
    const f = (dist - ideal) / dist * alpha * 0.5;
    if (!s.fx) { s.vx += dx*f; s.vy += dy*f; }
    if (!t2.fx) { t2.vx -= dx*f; t2.vy -= dy*f; }
  }
  // Repulsion
  for (let i = 0; i < KG_NODES.length; i++) {
    for (let j = i+1; j < KG_NODES.length; j++) {
      const a = KG_NODES[i], b = KG_NODES[j];
      const dx = b.x-a.x, dy = b.y-a.y;
      const dist = Math.sqrt(dx*dx+dy*dy) || 1;
      const minDist = a.r + b.r + 50;
      if (dist < minDist) {
        const f = (minDist - dist) / dist * 0.4;
        if (!a.fx) { a.vx -= dx*f; a.vy -= dy*f; }
        if (!b.fx) { b.vx += dx*f; b.vy += dy*f; }
      }
    }
  }
  // Center pull (right half)
  const cx = W*0.65, cy = H*0.5;
  KG_NODES.forEach(n => {
    if (n.fx !== null) { n.x = n.fx; n.y = n.fy; return; }
    n.vx += (cx - n.x) * 0.002;
    n.vy += (cy - n.y) * 0.002;
    n.vx *= 0.85; n.vy *= 0.85;
    n.x += n.vx; n.y += n.vy;
    // Keep in right half
    n.x = Math.max(W*0.46 + n.r, Math.min(W - n.r - 4, n.x));
    n.y = Math.max(n.r + 4, Math.min(H - n.r - 4, n.y));
  });
}

/* ── Drag ── */
let dragging = null;

canvas.addEventListener('mousedown', e => {
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2) { dragging = n; n.fx = n.x; n.fy = n.y; break; }
  }
});

canvas.addEventListener('mousemove', e => {
  if (dragging) { dragging.fx = mouse.x; dragging.fy = mouse.y; }
});

canvas.addEventListener('mouseup', e => {
  if (dragging) { dragging.fx = null; dragging.fy = null; dragging = null; }
});

canvas.addEventListener('click', e => {
  if (dragging) return;
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2 && n.url) { window.location.href = n.url; break; }
  }
});

/* ── Hover detection ── */
let hoveredNode = null;
canvas.addEventListener('mousemove', () => {
  if (dragging) { canvas.style.cursor = 'grabbing'; return; }
  hoveredNode = null;
  for (const n of KG_NODES) {
    const dx = mouse.x-n.x, dy = mouse.y-n.y;
    if (dx*dx+dy*dy < (n.r+8)**2) { hoveredNode = n; break; }
  }
  canvas.style.cursor = hoveredNode ? (hoveredNode.url ? 'pointer' : 'grab') : 'none';
});

/* ── Background ambient nodes ── */
const BG_NODES = Array.from({ length: 45 }, () => ({
  x: Math.random(), y: Math.random(),
  vx: (Math.random()-0.5)*0.00012, vy: (Math.random()-0.5)*0.00012,
  r: Math.random()*2+0.8,
  pulse: Math.random()*Math.PI*2, pSpeed: 0.02+Math.random()*0.025,
  col: ['rgba(167,139,250,','rgba(6,182,212,','rgba(16,185,129,'][Math.floor(Math.random()*3)],
}));

/* ── Signals ── */
const signals = [];
function spawnSignal() {
  const link = KG_LINKS[Math.floor(Math.random()*KG_LINKS.length)];
  const s = nodeMap[link[0]], t2 = nodeMap[link[1]];
  if (s && t2) signals.push({ s, t2, progress: 0, speed: 0.006+Math.random()*0.007 });
}
setInterval(spawnSignal, 350);

/* ── Colour helpers ── */
function darken(hex, amt) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgb(${Math.max(0,r-amt)},${Math.max(0,g-amt)},${Math.max(0,b-amt)})`;
}

/* ── Wobbly blob path (hand-drawn feel) ── */
function wobblyPath(cx, cy, r, wpts) {
  const pts = wpts.map(p => ({
    x: cx + Math.cos(p.angle) * r * p.rf,
    y: cy + Math.sin(p.angle) * r * p.rf,
  }));
  ctx.beginPath();
  ctx.moveTo((pts[0].x + pts[pts.length-1].x)/2, (pts[0].y + pts[pts.length-1].y)/2);
  for (let i = 0; i < pts.length; i++) {
    const a = pts[i], b = pts[(i+1) % pts.length];
    ctx.quadraticCurveTo(a.x, a.y, (a.x+b.x)/2, (a.y+b.y)/2);
  }
  ctx.closePath();
}

/* ── Draw node — flat hand-drawn blob style ── */
function drawPlanet(n) {
  const isHov = n === hoveredNode;
  const isDrag = n === dragging;
  const bob = isDrag ? 0 : Math.sin(t * 1.9 + n.x * 0.009) * 3;
  const scale = isDrag ? 1.1 : (isHov ? 1.06 : 1);
  const r = n.r * scale;
  const cx = n.x, cy = n.y + bob;

  function shape() { wobblyPath(cx, cy, r, n.wpts); }

  // === Flat fill — zero gradients ===
  shape(); ctx.fillStyle = n.color; ctx.fill();

  // Flat shadow blob (darker color, bottom-right, clipped to shape)
  ctx.save(); shape(); ctx.clip();
  ctx.fillStyle = 'rgba(0,0,0,0.22)';
  ctx.beginPath(); ctx.arc(cx + r*0.28, cy + r*0.32, r*0.95, 0, Math.PI*2); ctx.fill();
  ctx.restore();

  // Flat highlight blob (white, top-left, clipped)
  ctx.save(); shape(); ctx.clip();
  ctx.fillStyle = 'rgba(255,255,255,0.52)';
  ctx.beginPath(); ctx.arc(cx - r*0.28, cy - r*0.26, r*0.38, 0, Math.PI*2); ctx.fill();
  ctx.restore();

  // Hand-drawn thick dark outline
  shape();
  ctx.strokeStyle = '#0c0820';
  ctx.lineWidth = n.type === 'root' ? 4 : 3;
  ctx.lineJoin = 'round'; ctx.lineCap = 'round';
  ctx.stroke();

  // Second slightly-offset stroke for sketchy double-line feel
  ctx.save();
  ctx.translate(1.2, 1.2);
  shape();
  ctx.strokeStyle = 'rgba(0,0,0,0.18)';
  ctx.lineWidth = n.type === 'root' ? 3 : 2;
  ctx.stroke();
  ctx.restore();

  // Hover: dashed colored outer ring
  if (isHov || isDrag) {
    shape();
    ctx.strokeStyle = n.color;
    ctx.lineWidth = 3;
    ctx.setLineDash([7, 4]); ctx.stroke(); ctx.setLineDash([]);
  }

  // URL dot
  if (n.url) {
    ctx.beginPath(); ctx.arc(cx + r*0.7, cy - r*0.7, 5.5, 0, Math.PI*2);
    ctx.fillStyle = isHov ? '#ffffff' : '#f472b6';
    ctx.strokeStyle = '#0c0820'; ctx.lineWidth = 2;
    ctx.fill(); ctx.stroke();
  }

  // Label — only on hover / drag
  if (isHov || isDrag) {
    const label = n.url ? `${n.label} →` : n.label;
    const fSize = Math.max(11, n.r * 0.78);
    ctx.font = `800 ${fSize}px sans-serif`;
    const tw = ctx.measureText(label).width;
    const lx = cx, ly = cy - r - 18;
    ctx.fillStyle = n.color;
    ctx.beginPath(); ctx.roundRect(lx - tw/2 - 12, ly - fSize/2 - 6, tw + 24, fSize + 12, 999); ctx.fill();
    ctx.strokeStyle = '#0c0820'; ctx.lineWidth = 2.5; ctx.stroke();
    ctx.fillStyle = '#ffffff';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(label, lx, ly);
  }
}

/* ── Draw comet ── */
function drawComet() {
  if (cometTrail.length < 2) return;
  for (let i = 1; i < cometTrail.length; i++) {
    const ratio = 1 - i/cometTrail.length;
    const a = cometTrail[i-1], b = cometTrail[i];
    ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
    ctx.strokeStyle = `rgba(255,255,255,${ratio*0.55})`;
    ctx.lineWidth = ratio*3; ctx.lineCap = 'round'; ctx.stroke();
  }
  const g = ctx.createRadialGradient(mouse.x,mouse.y,0,mouse.x,mouse.y,10);
  g.addColorStop(0,'rgba(255,255,255,0.9)');
  g.addColorStop(0.4,'rgba(167,139,250,0.6)');
  g.addColorStop(1,'rgba(0,0,0,0)');
  ctx.beginPath(); ctx.arc(mouse.x,mouse.y,10,0,Math.PI*2);
  ctx.fillStyle = g; ctx.fill();
  ctx.beginPath(); ctx.arc(mouse.x,mouse.y,2.5,0,Math.PI*2);
  ctx.fillStyle = 'rgba(255,255,255,0.95)'; ctx.fill();
}

/* ── Main loop ── */
function animate() {
  t += 0.014;
  ctx.clearRect(0, 0, W, H);

  // BG
  const bg = ctx.createLinearGradient(0,0,W,H);
  bg.addColorStop(0,'#05050e'); bg.addColorStop(0.5,'#090916'); bg.addColorStop(1,'#070710');
  ctx.fillStyle = bg; ctx.fillRect(0,0,W,H);

  // Ambient
  [[W*0.18,H*0.4,300,'rgba(124,58,237,0.055)'],[W*0.72,H*0.5,260,'rgba(6,182,212,0.04)'],[W*0.5,H*0.2,180,'rgba(16,185,129,0.03)']].forEach(([bx,by,br,bc])=>{
    const g=ctx.createRadialGradient(bx,by,0,bx,by,br);
    g.addColorStop(0,bc); g.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  });

  // BG ambient nodes
  const CDIST = Math.min(W,H)*0.18;
  BG_NODES.forEach(n => {
    n.x+=n.vx; n.y+=n.vy;
    if(n.x<0||n.x>1)n.vx*=-1; if(n.y<0||n.y>1)n.vy*=-1;
    n.pulse+=n.pSpeed;
    const px=n.x*W,py=n.y*H,r=n.r*(1+Math.sin(n.pulse)*0.3);
    const g=ctx.createRadialGradient(px,py,0,px,py,r*3.5);
    g.addColorStop(0,n.col+'0.2)'); g.addColorStop(1,n.col+'0)');
    ctx.beginPath(); ctx.arc(px,py,r*3.5,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
    ctx.beginPath(); ctx.arc(px,py,r,0,Math.PI*2);
    ctx.fillStyle=n.col+`${0.5+Math.sin(n.pulse)*0.25})`; ctx.fill();
  });

  // BG edges
  for(let i=0;i<BG_NODES.length;i++) for(let j=i+1;j<BG_NODES.length;j++){
    const a=BG_NODES[i],b=BG_NODES[j];
    const dx=(a.x-b.x)*W,dy=(a.y-b.y)*H,dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<CDIST){ctx.beginPath();ctx.moveTo(a.x*W,a.y*H);ctx.lineTo(b.x*W,b.y*H);ctx.strokeStyle=`rgba(167,139,250,${(1-dist/CDIST)*0.1})`;ctx.lineWidth=0.5;ctx.stroke();}
  }

  // Force tick
  tickForce();

  // KG links — bold flat style
  for (const [sid,tid] of KG_LINKS) {
    const s=nodeMap[sid],t2=nodeMap[tid]; if(!s||!t2) continue;
    // thick dark shadow
    ctx.beginPath(); ctx.moveTo(s.x,s.y+2); ctx.lineTo(t2.x,t2.y+2);
    ctx.strokeStyle='rgba(0,0,0,0.35)'; ctx.lineWidth=4; ctx.lineCap='round'; ctx.stroke();
    // coloured line (blend of source node color)
    const [rr,gg,bb] = hexToRgb(s.color);
    ctx.beginPath(); ctx.moveTo(s.x,s.y); ctx.lineTo(t2.x,t2.y);
    ctx.strokeStyle=`rgba(${rr},${gg},${bb},0.45)`; ctx.lineWidth=3; ctx.stroke();
  }

  // Signals on KG links — flat dot, no gradient
  for(let i=signals.length-1;i>=0;i--){
    const sig=signals[i]; sig.progress+=sig.speed;
    if(sig.progress>=1){signals.splice(i,1);continue;}
    const sx=sig.s.x+(sig.t2.x-sig.s.x)*sig.progress;
    const sy=sig.s.y+(sig.t2.y-sig.s.y)*sig.progress;
    ctx.beginPath(); ctx.arc(sx,sy,4,0,Math.PI*2);
    ctx.fillStyle=sig.s.color; ctx.fill();
    ctx.strokeStyle='#0c0820'; ctx.lineWidth=1.5; ctx.stroke();
  }

  // Divider
  ctx.beginPath(); ctx.moveTo(W*0.47,H*0.08); ctx.lineTo(W*0.47,H*0.92);
  ctx.strokeStyle='rgba(45,45,78,0.4)'; ctx.lineWidth=1;
  ctx.setLineDash([4,10]); ctx.stroke(); ctx.setLineDash([]);

  // Planets (KG nodes)
  KG_NODES.forEach(n => drawPlanet(n));

  // Comet on top
  drawComet();

  requestAnimationFrame(animate);
}

resize();
requestAnimationFrame(animate);
</script>

<style>
.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
  cursor: none;
}

#neural-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-left {
  position: absolute;
  z-index: 10;
  top: 50%;
  left: 3rem;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  max-width: 340px;
  pointer-events: none;
}

.badge {
  display: inline-block;
  font-size: 0.62rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #67e8f9;
  border: 1px solid rgba(103,232,249,0.35);
  padding: 0.25rem 0.9rem;
  border-radius: 999px;
  margin-bottom: 1.4rem;
  background: rgba(6,182,212,0.07);
  width: fit-content;
}

.scene-left h1 {
  font-size: clamp(3rem, 5vw, 5rem);
  line-height: 0.95;
  margin: 0 0 1.3rem;
  background: linear-gradient(135deg, #f8fafc 0%, #c4b5fd 50%, #67e8f9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.tagline {
  color: rgba(200,195,230,0.78);
  font-size: 0.88rem;
  line-height: 1.75;
  margin: 0 0 1.8rem;
  white-space: pre-line;
}

.hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  color: white;
  padding: 0.7rem 1.9rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.87rem;
  box-shadow: 0 0 28px rgba(124,58,237,0.5);
  width: fit-content;
  margin-bottom: 1.5rem;
  pointer-events: all;
  transition: transform 0.2s, box-shadow 0.2s;
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 40px rgba(124,58,237,0.7);
  color: white;
  text-decoration: none;
  cursor: pointer;
}

.graph-hint {
  font-size: 0.72rem;
  color: rgba(167,139,250,0.5);
  letter-spacing: 0.06em;
  animation: hint-fade 2.5s ease-in-out infinite;
