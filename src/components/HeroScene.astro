---
const lang = Astro.currentLocale ?? 'en';
---

<section class="hero-scene" id="hero-scene">
  <canvas id="scene-canvas"></canvas>

  <div class="scene-overlay">
    <div class="hero-text">
      <span class="badge">Biotech · Neuroscience · 2025</span>
      <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
      <p>{lang === 'zh'
        ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
        : 'Biotech insights from inside the lab\nInnovative drugs · Neuroscience · Metabolism'}</p>
      <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
        {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
      </a>
    </div>
    <p class="click-hint">{lang === 'zh' ? '点击框架探索' : 'Click frames to explore'}</p>
  </div>

  <!-- Knowledge graph modal -->
  <div class="kg-modal" id="kg-modal">
    <div class="kg-modal-panel">
      <button class="kg-close" id="kg-close">✕</button>
      <div id="kg-content"></div>
    </div>
  </div>
</section>

<script define:vars={{ lang }}>
const canvas = document.getElementById('scene-canvas');
const ctx = canvas.getContext('2d');
let W = 0, H = 0;
const mouse = { x: -9999, y: -9999 };
let t = 0;

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  initFrames();
}

/* ── Organ + molecule data ── */
const ORGANS = [
  {
    shape: 'square', label: lang === 'zh' ? '肝脏' : 'Liver',
    icon: 'liver', color: '#c2855a',
    molecules: ['Glucose', 'Bile Acids', 'ALT/AST', 'Fatty Acids', 'MASH'],
    desc: lang === 'zh' ? '糖代谢 · 胆汁合成 · MASH' : 'Glucose metabolism · MASH',
  },
  {
    shape: 'circle', label: lang === 'zh' ? '大脑' : 'Brain',
    icon: 'brain', color: '#7c6fa0',
    molecules: ['Dopamine', 'Serotonin', 'BDNF', 'Tau', 'BCI'],
    desc: lang === 'zh' ? '多巴胺 · 血清素 · 神经退行' : 'Dopamine · Serotonin · BCI',
  },
  {
    shape: 'square', label: lang === 'zh' ? '心脏' : 'Heart',
    icon: 'heart', color: '#c25a6a',
    molecules: ['Troponin', 'ATP', 'BNP', 'Actin', 'Myosin'],
    desc: lang === 'zh' ? '肌钙蛋白 · 心肌能量代谢' : 'Troponin · Cardiac metabolism',
  },
  {
    shape: 'circle', label: lang === 'zh' ? '脂肪' : 'Adipose',
    icon: 'fat', color: '#d4a843',
    molecules: ['Triglyceride', 'Leptin', 'Adiponectin', 'GLP-1', 'Lipase'],
    desc: lang === 'zh' ? '甘油三酯 · 瘦素 · GLP-1' : 'Triglyceride · Leptin · GLP-1',
  },
  {
    shape: 'square', label: lang === 'zh' ? '胰腺' : 'Pancreas',
    icon: 'pancreas', color: '#5a8ac2',
    molecules: ['Insulin', 'Glucagon', 'GLP-1', 'Amylase', 'β-cell'],
    desc: lang === 'zh' ? '胰岛素 · 胰高血糖素 · GLP-1' : 'Insulin · Glucagon · GLP-1',
  },
  {
    shape: 'circle', label: lang === 'zh' ? '肌肉' : 'Muscle',
    icon: 'muscle', color: '#6a9e6a',
    molecules: ['Actin', 'Myosin', 'Collagen', 'mTOR', 'Creatine'],
    desc: lang === 'zh' ? '肌动蛋白 · mTOR · 胶原' : 'Actin · mTOR · Collagen',
  },
  {
    shape: 'square', label: lang === 'zh' ? '脾' : 'Spleen',
    icon: 'spleen', color: '#8a6aa0',
    molecules: ['IgG', 'IL-6', 'B-cell', 'T-cell', 'Macrophage'],
    desc: lang === 'zh' ? 'B细胞 · T细胞 · 抗体' : 'B-cells · T-cells · IgG',
  },
];

/* Frame positions — will be set on resize */
let frames = [];

function initFrames() {
  const cx = W * 0.52, cy = H * 0.5;
  const spread = Math.min(W, H) * 0.34;
  const positions = [
    { x: cx - spread * 0.55, y: cy - spread * 0.75 },
    { x: cx + spread * 0.55, y: cy - spread * 0.6  },
    { x: cx - spread * 0.75, y: cy - spread * 0.1  },
    { x: cx + spread * 0.7,  y: cy + spread * 0.05 },
    { x: cx - spread * 0.4,  y: cy + spread * 0.65 },
    { x: cx + spread * 0.3,  y: cy + spread * 0.7  },
    { x: cx + spread * 0.05, y: cy - spread * 0.15 },
  ];

  frames = ORGANS.map((org, i) => ({
    ...org,
    x: positions[i].x,
    y: positions[i].y,
    baseX: positions[i].x,
    baseY: positions[i].y,
    floatOffset: Math.random() * Math.PI * 2,
    floatSpeed: 0.4 + Math.random() * 0.3,
    size: org.shape === 'square' ? 68 : 60,
    state: 'organ',    // 'organ' | 'molecule'
    alpha: 1,
    hover: false,
    clicked: false,
    transitionAlpha: 0,
  }));
}

window.addEventListener('resize', resize);
resize();

/* ── Canvas interactions ── */
function getFrame(ex, ey) {
  for (const f of frames) {
    const dx = ex - f.x, dy = ey - f.y;
    const hit = f.shape === 'square'
      ? Math.abs(dx) < f.size / 2 + 6 && Math.abs(dy) < f.size / 2 + 6
      : dx * dx + dy * dy < (f.size / 2 + 6) ** 2;
    if (hit) return f;
  }
  return null;
}

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  const hit = getFrame(mouse.x, mouse.y);
  frames.forEach(f => f.hover = f === hit);
  canvas.style.cursor = hit ? 'pointer' : 'default';
});

canvas.addEventListener('click', e => {
  const r = canvas.getBoundingClientRect();
  const hit = getFrame(e.clientX - r.left, e.clientY - r.top);
  if (hit) {
    hit.state = hit.state === 'organ' ? 'molecule' : 'organ';
    showModal(hit);
  }
});

document.getElementById('kg-close')?.addEventListener('click', () => {
  document.getElementById('kg-modal').classList.remove('open');
});
document.getElementById('kg-modal')?.addEventListener('click', e => {
  if (e.target.id === 'kg-modal') document.getElementById('kg-modal').classList.remove('open');
});

function showModal(frame) {
  const modal = document.getElementById('kg-modal');
  const content = document.getElementById('kg-content');
  content.innerHTML = `
    <h2 style="color:var(--accent-2);margin:0 0 0.8rem;font-size:1.3rem">${frame.label}</h2>
    <p style="color:var(--text-muted);font-size:0.85rem;margin:0 0 1.2rem">${frame.desc}</p>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
      ${frame.molecules.map(m => `<span style="background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.4);color:#a78bfa;padding:0.3rem 0.9rem;border-radius:999px;font-size:0.82rem;font-family:monospace">${m}</span>`).join('')}
    </div>
  `;
  modal.classList.add('open');
}

/* ── Draw helpers ── */
function drawMistyLandscape() {
  // Sky gradient (lavender→dusty blue→navy)
  const sky = ctx.createLinearGradient(0, 0, 0, H);
  sky.addColorStop(0, '#1a1040');
  sky.addColorStop(0.35, '#2d1b69');
  sky.addColorStop(0.65, '#4a2c8a');
  sky.addColorStop(1, '#0d0d20');
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, W, H);

  // Mist layers
  for (let i = 0; i < 3; i++) {
    const mistY = H * (0.45 + i * 0.12);
    const mist = ctx.createLinearGradient(0, mistY - 60, 0, mistY + 80);
    mist.addColorStop(0, 'rgba(200,180,230,0)');
    mist.addColorStop(0.4, `rgba(180,160,220,${0.07 - i * 0.02})`);
    mist.addColorStop(1, 'rgba(100,80,160,0)');
    ctx.fillStyle = mist;
    ctx.fillRect(0, mistY - 60, W, 140);
  }

  // Mountain silhouettes
  ctx.fillStyle = 'rgba(20,12,50,0.7)';
  ctx.beginPath();
  ctx.moveTo(0, H);
  ctx.lineTo(0, H * 0.72);
  ctx.bezierCurveTo(W * 0.12, H * 0.58, W * 0.22, H * 0.62, W * 0.35, H * 0.68);
  ctx.bezierCurveTo(W * 0.45, H * 0.55, W * 0.55, H * 0.52, W * 0.65, H * 0.6);
  ctx.bezierCurveTo(W * 0.75, H * 0.65, W * 0.88, H * 0.7, W, H * 0.73);
  ctx.lineTo(W, H);
  ctx.closePath();
  ctx.fill();

  // Foreground darker
  ctx.fillStyle = 'rgba(10,6,30,0.85)';
  ctx.beginPath();
  ctx.moveTo(0, H);
  ctx.lineTo(0, H * 0.88);
  ctx.bezierCurveTo(W * 0.2, H * 0.82, W * 0.4, H * 0.85, W * 0.6, H * 0.83);
  ctx.bezierCurveTo(W * 0.8, H * 0.81, W * 0.9, H * 0.86, W, H * 0.88);
  ctx.lineTo(W, H);
  ctx.closePath();
  ctx.fill();

  // Grain overlay
  ctx.globalAlpha = 0.03;
  for (let i = 0; i < 3000; i++) {
    ctx.fillStyle = Math.random() > 0.5 ? '#fff' : '#000';
    ctx.fillRect(Math.random() * W, Math.random() * H, 1, 1);
  }
  ctx.globalAlpha = 1;
}

function drawOrganIcon(ctx, type, cx, cy, size, col) {
  const s = size * 0.35;
  ctx.strokeStyle = col;
  ctx.lineWidth = 2;
  ctx.fillStyle = col + '33';

  if (type === 'liver') {
    ctx.beginPath();
    ctx.moveTo(cx - s, cy);
    ctx.bezierCurveTo(cx - s, cy - s * 1.2, cx + s * 0.5, cy - s * 1.1, cx + s, cy - s * 0.3);
    ctx.bezierCurveTo(cx + s * 1.2, cy + s * 0.4, cx + s * 0.3, cy + s * 1.1, cx - s * 0.2, cy + s);
    ctx.bezierCurveTo(cx - s * 0.8, cy + s * 0.8, cx - s * 1.1, cy + s * 0.4, cx - s, cy);
    ctx.fill(); ctx.stroke();

  } else if (type === 'brain') {
    // Two lobes
    ctx.beginPath();
    ctx.arc(cx - s * 0.3, cy, s * 0.8, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    ctx.beginPath();
    ctx.arc(cx + s * 0.3, cy, s * 0.7, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    // Fissure
    ctx.beginPath();
    ctx.moveTo(cx, cy - s * 0.6);
    ctx.lineTo(cx, cy + s * 0.6);
    ctx.strokeStyle = col;
    ctx.lineWidth = 1.5;
    ctx.stroke();

  } else if (type === 'heart') {
    ctx.beginPath();
    ctx.moveTo(cx, cy + s * 0.9);
    ctx.bezierCurveTo(cx - s * 1.1, cy + s * 0.1, cx - s * 1.2, cy - s * 0.7, cx - s * 0.5, cy - s * 0.7);
    ctx.bezierCurveTo(cx - s * 0.2, cy - s * 0.7, cx, cy - s * 0.4, cx, cy - s * 0.4);
    ctx.bezierCurveTo(cx, cy - s * 0.4, cx + s * 0.2, cy - s * 0.7, cx + s * 0.5, cy - s * 0.7);
    ctx.bezierCurveTo(cx + s * 1.2, cy - s * 0.7, cx + s * 1.1, cy + s * 0.1, cx, cy + s * 0.9);
    ctx.fill(); ctx.stroke();

  } else if (type === 'fat') {
    // Adipocyte clusters
    for (let i = 0; i < 6; i++) {
      const angle = (i / 6) * Math.PI * 2;
      const bx = cx + Math.cos(angle) * s * 0.55;
      const by = cy + Math.sin(angle) * s * 0.55;
      ctx.beginPath();
      ctx.arc(bx, by, s * 0.38, 0, Math.PI * 2);
      ctx.fill(); ctx.stroke();
    }
    ctx.beginPath();
    ctx.arc(cx, cy, s * 0.35, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();

  } else if (type === 'pancreas') {
    // Elongated S-shape
    ctx.beginPath();
    ctx.moveTo(cx - s, cy + s * 0.3);
    ctx.bezierCurveTo(cx - s * 0.3, cy - s * 0.8, cx + s * 0.3, cy + s * 0.8, cx + s, cy - s * 0.3);
    ctx.lineWidth = s * 0.7;
    ctx.lineCap = 'round';
    ctx.strokeStyle = col + '66';
    ctx.stroke();
    ctx.lineWidth = 2;
    ctx.lineCap = 'butt';
    ctx.strokeStyle = col;
    ctx.stroke();

  } else if (type === 'muscle') {
    // Parallel fibers
    for (let i = -2; i <= 2; i++) {
      ctx.beginPath();
      ctx.moveTo(cx - s, cy + i * s * 0.38);
      ctx.bezierCurveTo(cx - s * 0.3, cy + i * s * 0.38 - s * 0.1,
                        cx + s * 0.3, cy + i * s * 0.38 + s * 0.1, cx + s, cy + i * s * 0.38);
      ctx.stroke();
    }

  } else if (type === 'spleen') {
    // Bean shape
    ctx.beginPath();
    ctx.ellipse(cx, cy, s * 0.6, s, 0.3, 0, Math.PI * 2);
    ctx.fill(); ctx.stroke();
    ctx.beginPath();
    ctx.ellipse(cx - s * 0.1, cy, s * 0.3, s * 0.7, 0.3, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(10,6,30,0.5)';
    ctx.fill();
  }
}

function drawMoleculeIcon(ctx, molecules, cx, cy, size) {
  const cols = ['#a78bfa','#06b6d4','#34d399','#fbbf24','#f87171','#c084fc'];
  const r = size * 0.28;
  const count = Math.min(molecules.length, 5);
  // Draw as force-like cluster
  const positions = [
    {x: 0,    y: 0},
    {x: -r*1.5, y: -r},
    {x: r*1.5,  y: -r},
    {x: -r*1.3, y: r*1.2},
    {x: r*1.3,  y: r*1.2},
  ];

  // Bonds
  for (let i = 1; i < count; i++) {
    ctx.beginPath();
    ctx.moveTo(cx + positions[0].x, cy + positions[0].y);
    ctx.lineTo(cx + positions[i].x, cy + positions[i].y);
    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  // Atoms
  for (let i = 0; i < count; i++) {
    const pr = i === 0 ? r * 0.85 : r * 0.6;
    const grd = ctx.createRadialGradient(
      cx + positions[i].x - pr*0.3, cy + positions[i].y - pr*0.3, pr*0.1,
      cx + positions[i].x, cy + positions[i].y, pr);
    grd.addColorStop(0, 'rgba(255,255,255,0.6)');
    grd.addColorStop(1, cols[i % cols.length]);
    ctx.beginPath();
    ctx.arc(cx + positions[i].x, cy + positions[i].y, pr, 0, Math.PI * 2);
    ctx.fillStyle = grd;
    ctx.fill();
  }

  // Center label
  ctx.fillStyle = 'rgba(255,255,255,0.85)';
  ctx.font = `bold ${Math.max(8, size * 0.13)}px monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(molecules[0], cx + positions[0].x, cy + positions[0].y);
}

function drawFrame(f, time) {
  const floatY = Math.sin(time * f.floatSpeed + f.floatOffset) * 5;
  f.y = f.baseY + floatY;

  const hw = f.size / 2;
  ctx.save();
  ctx.translate(f.x, f.y);

  // Frame background
  if (f.shape === 'square') {
    const bg = ctx.createLinearGradient(-hw, -hw, hw, hw);
    bg.addColorStop(0, 'rgba(240,230,255,0.92)');
    bg.addColorStop(1, 'rgba(210,200,240,0.85)');
    ctx.fillStyle = bg;
    ctx.fillRect(-hw, -hw, f.size, f.size);
    ctx.strokeStyle = f.hover ? 'rgba(167,139,250,0.9)' : 'rgba(200,190,230,0.7)';
    ctx.lineWidth = f.hover ? 2 : 1.5;
    ctx.strokeRect(-hw, -hw, f.size, f.size);
  } else {
    const bg = ctx.createRadialGradient(0, 0, 0, 0, 0, hw);
    bg.addColorStop(0, 'rgba(245,235,210,0.92)');
    bg.addColorStop(1, 'rgba(220,205,170,0.85)');
    ctx.beginPath();
    ctx.arc(0, 0, hw, 0, Math.PI * 2);
    ctx.fillStyle = bg;
    ctx.fill();
    ctx.strokeStyle = f.hover ? 'rgba(167,139,250,0.9)' : 'rgba(200,185,140,0.7)';
    ctx.lineWidth = f.hover ? 2 : 1.5;
    ctx.stroke();
  }

  // Hover glow
  if (f.hover) {
    ctx.globalAlpha = 0.25;
    ctx.beginPath();
    if (f.shape === 'square') ctx.rect(-hw - 6, -hw - 6, f.size + 12, f.size + 12);
    else ctx.arc(0, 0, hw + 8, 0, Math.PI * 2);
    ctx.fillStyle = '#a78bfa';
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  // Content: organ or molecule
  if (f.state === 'organ') {
    drawOrganIcon(ctx, f.icon, 0, 0, f.size, f.color);
  } else {
    drawMoleculeIcon(ctx, f.molecules, 0, 0, f.size);
  }

  // Label below
  ctx.fillStyle = f.shape === 'square' ? 'rgba(30,20,60,0.75)' : 'rgba(60,45,20,0.75)';
  ctx.font = `600 ${Math.max(8, f.size * 0.17)}px sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.fillText(f.label, 0, hw + 5);

  ctx.restore();
}

function drawConnections(time) {
  // Central red sphere position
  const cx = W * 0.52, cy = H * 0.46;

  // Draw curved lines from center to each frame
  frames.forEach((f, i) => {
    const progress = (Math.sin(time * 0.8 + i * 0.7) + 1) / 2;
    ctx.save();
    ctx.beginPath();
    const mx = (cx + f.x) / 2 + Math.sin(time * 0.5 + i) * 25;
    const my = (cy + f.y) / 2 + Math.cos(time * 0.4 + i) * 20;
    ctx.moveTo(cx, cy);
    ctx.quadraticCurveTo(mx, my, f.x, f.y);
    ctx.strokeStyle = `rgba(200,60,60,${0.25 + progress * 0.15})`;
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 8]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Traveling dot
    const dotT = (time * 0.4 + i * 0.5) % 1;
    const dotX = (1-dotT)*(1-dotT)*cx + 2*(1-dotT)*dotT*mx + dotT*dotT*f.x;
    const dotY = (1-dotT)*(1-dotT)*cy + 2*(1-dotT)*dotT*my + dotT*dotT*f.y;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(220,80,80,${0.6 + progress * 0.3})`;
    ctx.fill();
    ctx.restore();
  });

  // Central red sphere
  const pulse = 1 + Math.sin(time * 1.2) * 0.08;
  const grd = ctx.createRadialGradient(cx - 5, cy - 5, 2, cx, cy, 18 * pulse);
  grd.addColorStop(0, '#ff6b6b');
  grd.addColorStop(0.5, '#cc2222');
  grd.addColorStop(1, '#880000');
  ctx.beginPath();
  ctx.arc(cx, cy, 18 * pulse, 0, Math.PI * 2);
  ctx.fillStyle = grd;
  ctx.fill();
  // Glow
  ctx.beginPath();
  ctx.arc(cx, cy, 30 * pulse, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(200,40,40,0.15)';
  ctx.fill();
}

/* ── Animate ── */
let grainCache = null;
let grainFrame = 0;

function animate() {
  t += 0.015;
  ctx.clearRect(0, 0, W, H);

  drawMistyLandscape();
  drawConnections(t);
  frames.forEach(f => drawFrame(f, t));

  requestAnimationFrame(animate);
}
requestAnimationFrame(animate);
</script>

<style>
.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
}

#scene-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-overlay {
  position: relative;
  z-index: 10;
  padding: 2rem 3rem;
  max-width: 340px;
  pointer-events: none;
}

.badge {
  display: inline-block;
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-2);
  border: 1px solid rgba(6,182,212,0.4);
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  margin-bottom: 1rem;
  background: rgba(6,182,212,0.07);
}

.hero-text h1 {
  font-size: clamp(2.8rem, 5vw, 4.5rem);
  line-height: 1;
  margin: 0 0 1rem;
  background: linear-gradient(135deg, #f1f5f9 0%, #c4b5fd 50%, #67e8f9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.hero-text p {
  color: rgba(200,190,230,0.8);
  font-size: 0.88rem;
  line-height: 1.7;
  margin: 0 0 1.5rem;
  white-space: pre-line;
}

.hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  color: white;
  padding: 0.7rem 1.8rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.85rem;
  box-shadow: 0 0 24px rgba(124,58,237,0.45);
  pointer-events: all;
  transition: transform 0.2s, box-shadow 0.2s;
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 36px rgba(124,58,237,0.65);
  color: white;
  text-decoration: none;
}

.click-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(200,180,240,0.5);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  animation: hint-fade 2.5s ease-in-out infinite;
  white-space: nowrap;
  z-index: 10;
}
@keyframes hint-fade {
  0%, 100% { opacity: 0.3; } 50% { opacity: 0.8; }
}

/* Modal */
.kg-modal {
  position: absolute;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7,5,20,0);
  pointer-events: none;
  transition: background 0.3s;
}
.kg-modal.open {
