---
const lang = Astro.currentLocale ?? 'en';
const base = '/Circle-of-Life';
---

<section class="hero-scene" id="hero-scene">
  <!-- regi.it-style floating gradient orbs -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <canvas id="neural-canvas"></canvas>

  <div class="scene-left">
    <span class="badge">Biotech · Neuroscience · 2025</span>
    <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
    <p class="tagline">{lang === 'zh'
      ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
      : 'Biotech insights from inside the lab.\nInnovative drugs · Neuroscience · Metabolism.'}</p>
    <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
      {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
    </a>
    <p class="graph-hint">{lang === 'zh' ? '→ 拖拽行星 · 悬停查看 · 点击文章' : '→ Drag planets · Hover to reveal · Click for articles'}</p>
  </div>
</section>

<script define:vars={{ lang, base }}>
const canvas = document.getElementById('neural-canvas');
const ctx = canvas.getContext('2d');
let W = 0, H = 0;
let t = 0;

/* ── Mouse / regi.it-style cursor ── */
const mouse = { x: -9999, y: -9999 };
const ring = { x: -9999, y: -9999 };
let ringReady = false;

function onMouseMove(e) {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  if (!ringReady) { ring.x = mouse.x; ring.y = mouse.y; ringReady = true; }
}
window.addEventListener('mousemove', onMouseMove);

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  initKGPositions();
}
window.addEventListener('resize', resize);

/* ── Knowledge graph data ── */
const KG_NODES = [
  // Root gems — large faceted crystals
  { id: 'metabolism', label: lang === 'zh' ? '代谢' : 'Metabolism',    color: '#a8e840', r: 32, sides: 6, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuro',      label: lang === 'zh' ? '脑科学' : 'Neuroscience', color: '#50a8f0', r: 32, sides: 8, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'immune',     label: lang === 'zh' ? '免疫' : 'Immunology',     color: '#c060e8', r: 32, sides: 5, url: null,   type: 'root', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  // Metabolism leaves — diamond / kite shapes
  { id: 'mash',     label: 'MASH/MASLD',  color: '#90d840', r: 20, sides: 4, url: `${base}/blog/mash-pipeline-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'glp1',     label: 'GLP-1',        color: '#90d840', r: 18, sides: 4, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'lipid',    label: lang==='zh'?'脂质':'Lipid',        color: '#70c030', r: 16, sides: 6, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'insulin',  label: lang==='zh'?'胰岛素':'Insulin',    color: '#70c030', r: 16, sides: 4, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'mito',     label: lang==='zh'?'线粒体':'Mitochondria',color: '#50b020', r: 16, sides: 3, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  // Neuro leaves — crystal / triangular
  { id: 'bci',       label: 'BCI',           color: '#40a0e8', r: 20, sides: 3, url: `${base}/blog/bci-future-en/`, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'alzheimer', label: "Alzheimer's",   color: '#40a0e8', r: 16, sides: 4, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'parkinson', label: "Parkinson's",   color: '#2880c0', r: 16, sides: 6, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'neuromod',  label: lang==='zh'?'神经调控':'Neuromod', color: '#2880c0', r: 15, sides: 4, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },

  // Immune leaves — hexagonal / octagonal
  { id: 'cart',       label: 'CAR-T',          color: '#e060c8', r: 18, sides: 6, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'checkpoint', label: lang==='zh'?'检查点':'Checkpoint', color: '#c05890', r: 15, sides: 4, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'autoimmune', label: lang==='zh'?'自身免疫':'Autoimmune',color: '#b060e0', r: 15, sides: 8, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
  { id: 'senescence', label: lang==='zh'?'衰老':'Senescence',   color: '#9050c8', r: 15, sides: 3, url: null, type: 'leaf', x:0,y:0,vx:0,vy:0,fx:null,fy:null },
];

const KG_LINKS = [
  ['metabolism','mash'],['metabolism','glp1'],['metabolism','lipid'],
  ['metabolism','insulin'],['metabolism','mito'],
  ['neuro','bci'],['neuro','alzheimer'],['neuro','parkinson'],['neuro','neuromod'],
  ['immune','cart'],['immune','checkpoint'],['immune','autoimmune'],['immune','senescence'],
  ['glp1','mash'],['senescence','mito'],['insulin','alzheimer'],
];

const nodeMap = Object.fromEntries(KG_NODES.map(n => [n.id, n]));

/* ── Pre-compute per-node shape data ── */
KG_NODES.forEach(n => {
  // Wobbly outline points (used for non-root cells)
  const pts = 10;
  n.wpts = Array.from({ length: pts }, (_, i) => ({
    angle: (i / pts) * Math.PI * 2 + (Math.random() - 0.5) * 0.28,
    rf: 1 + (Math.random() - 0.5) * 0.18,
  }));
  // Surface bumps (protrusions on cell surface)
  const numBumps = n.type === 'root' ? 14 : Math.floor(6 + Math.random()*5);
  n.bumps = Array.from({ length: numBumps }, () => ({
    angle: Math.random() * Math.PI * 2,
    dist: 0.72 + Math.random() * 0.22,
    size: 0.09 + Math.random() * 0.11,
  }));
  // Per-node phase offset for organic drift
  n.phase = Math.random() * Math.PI * 2;
});

/* ── Star field ── */
const STARS = Array.from({ length: 220 }, () => ({
  x: Math.random(), y: Math.random(),
  r: 0.3 + Math.random() * 1.4,
  alpha: 0.25 + Math.random() * 0.75,
  twinkle: Math.random() * Math.PI * 2,
  tSpeed: 0.008 + Math.random() * 0.025,
}));

/* ── Nebula clouds ── */
const NEBULAS = [
  { x: 0.22, y: 0.42, r: 320, rgb: [90, 50, 200] },
  { x: 0.72, y: 0.52, r: 380, rgb: [30, 70, 210] },
  { x: 0.48, y: 0.18, r: 220, rgb: [180, 40, 130] },
  { x: 0.12, y: 0.75, r: 200, rgb: [30, 150, 180] },
];

function initKGPositions() {
  const cx = W * 0.62, cy = H * 0.5;
  const roots = KG_NODES.filter(n => n.type === 'root');
  roots.forEach((r, i) => {
    const angle = (i / roots.length) * Math.PI * 2 - Math.PI / 2;
    r.x = cx + Math.cos(angle) * Math.min(W, H) * 0.22;
    r.y = cy + Math.sin(angle) * Math.min(W, H) * 0.22;
  });
  KG_NODES.filter(n => n.type === 'leaf').forEach((n, i) => {
    n.x = cx + (Math.random() - 0.5) * W * 0.7;
    n.y = cy + (Math.random() - 0.5) * H * 0.85;
  });
}

/* ── Force simulation ── */
function tickForce() {
  const alpha = 0.06;
  // Link forces
  for (const [sid, tid] of KG_LINKS) {
    const s = nodeMap[sid], t2 = nodeMap[tid];
    if (!s || !t2) continue;
    const ideal = (s.type==='root'||t2.type==='root') ? 195 : 135;
    const dx = t2.x - s.x, dy = t2.y - s.y;
    const dist = Math.sqrt(dx*dx+dy*dy) || 1;
    const f = (dist - ideal) / dist * alpha * 0.5;
    if (!s.fx) { s.vx += dx*f; s.vy += dy*f; }
    if (!t2.fx) { t2.vx -= dx*f; t2.vy -= dy*f; }
  }
  // Repulsion
  for (let i = 0; i < KG_NODES.length; i++) {
    for (let j = i+1; j < KG_NODES.length; j++) {
      const a = KG_NODES[i], b = KG_NODES[j];
      const dx = b.x-a.x, dy = b.y-a.y;
      const dist = Math.sqrt(dx*dx+dy*dy) || 1;
      const minDist = a.r + b.r + 75;
      if (dist < minDist) {
        const f = (minDist - dist) / dist * 0.4;
        if (!a.fx) { a.vx -= dx*f; a.vy -= dy*f; }
        if (!b.fx) { b.vx += dx*f; b.vy += dy*f; }
      }
    }
  }
  // Center pull (spread across 2/3 of canvas)
  const cx = W*0.62, cy = H*0.5;
  KG_NODES.forEach(n => {
    if (n.fx !== null) { n.x = n.fx; n.y = n.fy; return; }
    n.vx += (cx - n.x) * 0.0015;
    n.vy += (cy - n.y) * 0.0015;
    n.vx *= 0.85; n.vy *= 0.85;
    n.x += n.vx; n.y += n.vy;
    // Allow spread across most of canvas (keep clear of text on left)
    n.x = Math.max(W*0.30 + n.r, Math.min(W - n.r - 8, n.x));
    n.y = Math.max(n.r + 8, Math.min(H - n.r - 8, n.y));
  });
}

/* ── Drag ── */
let dragging = null;

canvas.addEventListener('mousedown', e => {
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2) { dragging = n; n.fx = n.x; n.fy = n.y; break; }
  }
});

canvas.addEventListener('mousemove', e => {
  if (dragging) { dragging.fx = mouse.x; dragging.fy = mouse.y; }
});

canvas.addEventListener('mouseup', e => {
  if (dragging) { dragging.fx = null; dragging.fy = null; dragging = null; }
});

canvas.addEventListener('click', e => {
  if (dragging) return;
  const r = canvas.getBoundingClientRect();
  const px = e.clientX - r.left, py = e.clientY - r.top;
  for (const n of KG_NODES) {
    const dx = px-n.x, dy = py-n.y;
    if (dx*dx+dy*dy < (n.r+6)**2 && n.url) { window.location.href = n.url; break; }
  }
});

/* ── Hover detection ── */
let hoveredNode = null;
canvas.addEventListener('mousemove', () => {
  if (dragging) { canvas.style.cursor = 'grabbing'; return; }
  hoveredNode = null;
  for (const n of KG_NODES) {
    const dx = mouse.x-n.x, dy = mouse.y-n.y;
    if (dx*dx+dy*dy < (n.r+8)**2) { hoveredNode = n; break; }
  }
  canvas.style.cursor = hoveredNode ? (hoveredNode.url ? 'pointer' : 'grab') : 'none';
});

/* ── Background geometric shapes (Bauhaus / Surrealist floating forms) ── */
const SHAPE_COLS = [
  'rgba(110,207,160,', // sage
  'rgba(91,186,213,',  // teal
  'rgba(156,136,212,', // lavender
  'rgba(224,123,176,', // rose
  'rgba(232,160,80,',  // amber
];
const SHAPE_TYPES = ['circle', 'triangle', 'rect', 'circle', 'circle'];
const BG_SHAPES = Array.from({ length: 28 }, () => ({
  x: Math.random(), y: Math.random(),
  vx: (Math.random()-0.5)*0.00007, vy: (Math.random()-0.5)*0.00007,
  size: 12 + Math.random() * 40,
  rot: Math.random() * Math.PI * 2,
  rotV: (Math.random()-0.5) * 0.004,
  type: SHAPE_TYPES[Math.floor(Math.random()*SHAPE_TYPES.length)],
  col: SHAPE_COLS[Math.floor(Math.random()*SHAPE_COLS.length)],
  alpha: 0.06 + Math.random() * 0.1,
  hollow: Math.random() > 0.4,
}));

/* ── Signals ── */
const signals = [];
function spawnSignal() {
  const link = KG_LINKS[Math.floor(Math.random()*KG_LINKS.length)];
  const s = nodeMap[link[0]], t2 = nodeMap[link[1]];
  if (s && t2) signals.push({ s, t2, progress: 0, speed: 0.006+Math.random()*0.007 });
}
setInterval(spawnSignal, 350);

/* ── Colour helpers ── */
function hexToRgb(hex) {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}
function lighten(hex, amt) {
  const [r,g,b] = hexToRgb(hex);
  return `rgb(${Math.min(255,r+amt)},${Math.min(255,g+amt)},${Math.min(255,b+amt)})`;
}
function darken(hex, amt) {
  const [r,g,b] = hexToRgb(hex);
  return `rgb(${Math.max(0,r-amt)},${Math.max(0,g-amt)},${Math.max(0,b-amt)})`;
}

/* ── Wobbly blob path ── */
function wobblyPath(cx, cy, r, wpts) {
  const pts = wpts.map(p => ({
    x: cx + Math.cos(p.angle) * r * p.rf,
    y: cy + Math.sin(p.angle) * r * p.rf,
  }));
  ctx.beginPath();
  ctx.moveTo((pts[0].x + pts[pts.length-1].x)/2, (pts[0].y + pts[pts.length-1].y)/2);
  for (let i = 0; i < pts.length; i++) {
    const a = pts[i], b = pts[(i+1) % pts.length];
    ctx.quadraticCurveTo(a.x, a.y, (a.x+b.x)/2, (a.y+b.y)/2);
  }
  ctx.closePath();
}

/* ── Draw premium glass-orb node ── */
function drawGem(n) {
  const isHov = n === hoveredNode;
  const isDrag = n === dragging;
  const bob = isDrag ? 0 : Math.sin(t * 0.85 + n.phase) * 2;
  const scale = isDrag ? 1.1 : (isHov ? 1.07 : 1);
  const r = n.r * scale;
  const cx = n.x, cy = n.y + bob;
  const [rr, gg, bb] = hexToRgb(n.color);

  /* 1 — Soft outer glow */
  const glowR = r * (isHov ? 3.6 : 2.6);
  const glow = ctx.createRadialGradient(cx, cy, r * 0.7, cx, cy, glowR);
  glow.addColorStop(0, `rgba(${rr},${gg},${bb},${isHov ? 0.22 : 0.10})`);
  glow.addColorStop(1, `rgba(${rr},${gg},${bb},0)`);
  ctx.beginPath(); ctx.arc(cx, cy, glowR, 0, Math.PI*2);
  ctx.fillStyle = glow; ctx.fill();

  /* 2 — Frosted glass body */
  const body = ctx.createRadialGradient(cx - r*0.28, cy - r*0.28, 0, cx + r*0.08, cy + r*0.08, r*1.1);
  body.addColorStop(0,    'rgba(255,255,255,0.60)');
  body.addColorStop(0.22, `rgba(${Math.min(255,rr+55)},${Math.min(255,gg+55)},${Math.min(255,bb+45)},0.32)`);
  body.addColorStop(0.65, `rgba(${rr},${gg},${bb},0.16)`);
  body.addColorStop(1,    `rgba(${Math.max(0,rr-25)},${Math.max(0,gg-25)},${Math.max(0,bb-15)},0.06)`);
  ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2);
  ctx.fillStyle = body; ctx.fill();

  /* 3 — Crisp coloured rim */
  ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2);
  ctx.strokeStyle = `rgba(${rr},${gg},${bb},${n.type==='root' ? 0.85 : 0.60})`;
  ctx.lineWidth = n.type === 'root' ? 2 : 1.3; ctx.stroke();

  /* 4 — Top-arc glass shine (clipped) */
  ctx.save();
  ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2); ctx.clip();
  const shine = ctx.createLinearGradient(cx - r*0.6, cy - r, cx + r*0.4, cy - r*0.05);
  shine.addColorStop(0, 'rgba(255,255,255,0.50)');
  shine.addColorStop(0.6, 'rgba(255,255,255,0.12)');
  shine.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = shine; ctx.fillRect(cx-r, cy-r, r*2, r*0.9);
  ctx.restore();

  /* 5 — Sharp specular highlight */
  const spec = ctx.createRadialGradient(cx - r*0.29, cy - r*0.36, 0, cx - r*0.16, cy - r*0.22, r*0.42);
  spec.addColorStop(0, 'rgba(255,255,255,0.95)');
  spec.addColorStop(0.45, 'rgba(255,255,255,0.28)');
  spec.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath(); ctx.arc(cx - r*0.16, cy - r*0.22, r*0.42, 0, Math.PI*2);
  ctx.fillStyle = spec; ctx.fill();

  /* 6 — Hover / drag pulsing dashed ring */
  if (isHov || isDrag) {
    ctx.beginPath(); ctx.arc(cx, cy, r + 7 + Math.sin(t*3.5)*2.5, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(${rr},${gg},${bb},0.42)`;
    ctx.lineWidth = 1.2; ctx.setLineDash([3,7]); ctx.stroke(); ctx.setLineDash([]);
  }

  /* 7 — URL dot */
  if (n.url && !isHov) {
    ctx.beginPath(); ctx.arc(cx + r*0.68, cy - r*0.68, 3.5, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${rr},${gg},${bb},0.85)`; ctx.fill();
  }

  /* 8 — Label: always below for root, pill on hover for leaf */
  const showLabel = n.type === 'root' || isHov || isDrag;
  if (showLabel) {
    const label = (isHov || isDrag) && n.url ? `${n.label} →` : n.label;
    const fSize = n.type === 'root' ? Math.max(11, n.r * 0.5) : Math.max(10, n.r * 0.62);
    ctx.font = `${n.type === 'root' ? '600' : '500'} ${fSize}px 'DM Sans', sans-serif`;
    const tw = ctx.measureText(label).width;
    const lx = cx;

    if (n.type === 'root') {
      // Clean text below node, no pill
      const ly = cy + r + 14;
      ctx.fillStyle = `rgba(${rr},${gg},${bb},0.92)`;
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(label, lx, ly);
    } else {
      // Floating pill above node
      const ly = cy - r - 17;
      ctx.fillStyle = `rgba(${rr},${gg},${bb},0.90)`;
      ctx.beginPath(); ctx.roundRect(lx - tw/2 - 9, ly - fSize/2 - 4, tw + 18, fSize + 8, 3); ctx.fill();
      const lum = rr * 0.299 + gg * 0.587 + bb * 0.114;
      ctx.fillStyle = lum > 160 ? '#08061a' : '#ffffff';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(label, lx, ly);
    }
  }
}

/* ── Draw regi.it-style cursor ── */
function drawCursor() {
  if (!ringReady) return;
  // Lerp ring toward mouse
  ring.x += (mouse.x - ring.x) * 0.10;
  ring.y += (mouse.y - ring.y) * 0.10;

  const isOver = hoveredNode !== null;

  // Outer ring (lagged, scales up on hover)
  const ringR = isOver ? 28 + Math.sin(t * 4) * 2 : 20;
  ctx.beginPath(); ctx.arc(ring.x, ring.y, ringR, 0, Math.PI*2);
  ctx.strokeStyle = isOver ? 'rgba(120,150,255,0.85)' : 'rgba(160,150,230,0.45)';
  ctx.lineWidth = isOver ? 1.8 : 1.2; ctx.stroke();

  // Inner precision dot
  ctx.beginPath(); ctx.arc(mouse.x, mouse.y, isOver ? 4 : 3, 0, Math.PI*2);
  ctx.fillStyle = isOver ? '#7090ff' : 'rgba(180,170,240,0.85)';
  ctx.fill();
}

/* ── Main loop ── */
function animate() {
  t += 0.014;
  ctx.clearRect(0, 0, W, H);

  // Transparent canvas — CSS orbs show through
  ctx.clearRect(0, 0, W, H);

  // Subtle precision dot grid (data-viz feel)
  const gs = 28;
  ctx.fillStyle = 'rgba(100,120,255,0.07)';
  for (let gx = gs / 2; gx < W; gx += gs) {
    for (let gy = gs / 2; gy < H; gy += gs) {
      ctx.beginPath(); ctx.arc(gx, gy, 0.85, 0, Math.PI*2); ctx.fill();
    }
  }

  // Force tick
  tickForce();

  // KG links — curved arcs (Mid-Century organic flow)
  for (const [sid,tid] of KG_LINKS) {
    const s=nodeMap[sid],t2=nodeMap[tid]; if(!s||!t2) continue;
    const mx=(s.x+t2.x)/2, my=(s.y+t2.y)/2;
    const dx=t2.x-s.x, dy=t2.y-s.y, len=Math.sqrt(dx*dx+dy*dy)||1;
    const bend = 28;
    const cpx=mx-(dy/len)*bend, cpy=my+(dx/len)*bend;
    // gradient link — source colour to target colour
    const [srr,sgg,sbb]=hexToRgb(s.color);
    const [trr,tgg,tbb]=hexToRgb(t2.color);
    const lg=ctx.createLinearGradient(s.x,s.y,t2.x,t2.y);
    lg.addColorStop(0,`rgba(${srr},${sgg},${sbb},0.50)`);
    lg.addColorStop(1,`rgba(${trr},${tgg},${tbb},0.50)`);
    ctx.beginPath(); ctx.moveTo(s.x,s.y); ctx.quadraticCurveTo(cpx,cpy,t2.x,t2.y);
    ctx.strokeStyle=lg; ctx.lineWidth=1.5; ctx.lineCap='round'; ctx.stroke();
  }

  // Signals on KG links — flat dot, no gradient
  for(let i=signals.length-1;i>=0;i--){
    const sig=signals[i]; sig.progress+=sig.speed;
    if(sig.progress>=1){signals.splice(i,1);continue;}
    const sx=sig.s.x+(sig.t2.x-sig.s.x)*sig.progress;
    const sy=sig.s.y+(sig.t2.y-sig.s.y)*sig.progress;
    ctx.beginPath(); ctx.arc(sx,sy,4,0,Math.PI*2);
    ctx.fillStyle=sig.s.color; ctx.fill();
    ctx.strokeStyle='#0c0820'; ctx.lineWidth=1.5; ctx.stroke();
  }

  // Divider
  ctx.beginPath(); ctx.moveTo(W*0.47,H*0.1); ctx.lineTo(W*0.47,H*0.9);
  ctx.strokeStyle='rgba(100,120,255,0.12)'; ctx.lineWidth=1;
  ctx.setLineDash([3,12]); ctx.stroke(); ctx.setLineDash([]);

  // Gemstone nodes
  KG_NODES.forEach(n => drawGem(n));

  // regi.it cursor on top
  drawCursor();

  requestAnimationFrame(animate);
}

resize();
requestAnimationFrame(animate);
</script>

