---
const lang = Astro.currentLocale ?? 'en';
---

<section class="hero-scene" id="hero-scene">
  <!-- Original Liévano GIF as background -->
  <img src="/Circle-of-Life/hero-bg.gif" class="hero-bg" alt="" aria-hidden="true" />
  <div class="hero-bg-overlay"></div>

  <!-- Interactive canvas for frames -->
  <canvas id="scene-canvas"></canvas>

  <div class="scene-overlay">
    <div class="hero-text">
      <span class="badge">Biotech · Neuroscience · 2025</span>
      <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
      <p>{lang === 'zh'
        ? '研究者视角的生命科学洞见\n聚焦创新药与神经科学前沿'
        : 'Biotech insights from inside the lab\nInnovative drugs · Neuroscience · Metabolism'}</p>
      <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
        {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
      </a>
    </div>
    <p class="click-hint">{lang === 'zh' ? '↑ 点击框架探索分子世界' : '↑ Click frames to explore'}</p>
  </div>

  <!-- Info modal -->
  <div class="kg-modal" id="kg-modal">
    <div class="kg-modal-panel">
      <button class="kg-close" id="kg-close">✕</button>
      <div id="kg-content"></div>
    </div>
  </div>
</section>

<script define:vars={{ lang }}>
const canvas = document.getElementById('scene-canvas');
const ctx = canvas.getContext('2d');
let W = 0, H = 0;
let t = 0;
const mouse = { x: -9999, y: -9999 };

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  initFrames();
}

/* ── Organ / molecule data ── */
const ORGANS = [
  {
    shape: 'square',
    label: lang === 'zh' ? '肝脏' : 'Liver',
    img: 'bio-research',   // dark cell interior — fits liver cell visualization
    color: '#c2855a',
    molecules: ['Glucose', 'Bile Acids', 'ALT/AST', 'MASH', 'Fatty Acids'],
    desc: lang === 'zh' ? '糖代谢 · 胆汁合成 · MASH/MASLD' : 'Glucose metabolism · Bile synthesis · MASH',
  },
  {
    shape: 'circle',
    label: lang === 'zh' ? '大脑' : 'Brain',
    img: 'bio-research',   // giant cell with molecular orbit — fits neuroscience
    color: '#7c6fa0',
    molecules: ['Dopamine', 'Serotonin', 'BDNF', 'Tau', 'BCI'],
    desc: lang === 'zh' ? '多巴胺 · 血清素 · 脑机接口' : 'Dopamine · Serotonin · BCI',
  },
  {
    shape: 'square',
    label: lang === 'zh' ? '细胞膜' : 'Cell Membrane',
    img: 'bio-membrane',   // phospholipid bilayer 3D render
    color: '#c08080',
    molecules: ['Phospholipid', 'Channel Protein', 'Receptor', 'Lipid Raft'],
    desc: lang === 'zh' ? '磷脂双层 · 受体 · 离子通道' : 'Phospholipid bilayer · Receptors · Ion channels',
  },
  {
    shape: 'circle',
    label: lang === 'zh' ? '细胞' : 'Cell',
    img: 'bio-cell',       // Iris Joval flat cell diagram
    color: '#5a9a6a',
    molecules: ['Mitochondria', 'Nucleus', 'ER', 'Ribosome', 'Golgi'],
    desc: lang === 'zh' ? '线粒体 · 细胞核 · 内质网' : 'Mitochondria · Nucleus · Endoplasmic Reticulum',
  },
  {
    shape: 'square',
    label: lang === 'zh' ? '胰腺' : 'Pancreas',
    img: 'bio-pill',       // pill/molecular collage
    color: '#5a8ac2',
    molecules: ['Insulin', 'Glucagon', 'GLP-1', 'β-cell', 'Amylase'],
    desc: lang === 'zh' ? '胰岛素 · GLP-1 · 胰岛β细胞' : 'Insulin · GLP-1 · Pancreatic β-cells',
  },
  {
    shape: 'circle',
    label: lang === 'zh' ? '生命' : 'Life',
    img: 'bio-nature',     // person in landscape — nature/human
    color: '#6a9a5a',
    molecules: ['mTOR', 'Senolytics', 'NAD+', 'Telomere', 'Longevity'],
    desc: lang === 'zh' ? '长寿 · mTOR · 衰老生物学' : 'Longevity · mTOR · Senescence biology',
  },
  {
    shape: 'square',
    label: lang === 'zh' ? '脂肪' : 'Adipose',
    img: 'bio-membrane',   // reuse membrane (lipid texture)
    color: '#d4a843',
    molecules: ['Triglyceride', 'Leptin', 'Adiponectin', 'GLP-1', 'Lipase'],
    desc: lang === 'zh' ? '甘油三酯 · 瘦素 · GLP-1' : 'Triglyceride · Leptin · GLP-1',
  },
];

/* ── Preload images ── */
const IMGS = {};
const IMG_KEYS = ['bio-membrane','bio-cell','bio-research','bio-pill','bio-nature'];
let imgsLoaded = 0;
IMG_KEYS.forEach(key => {
  const img = new Image();
  img.src = `/Circle-of-Life/${key}.${key === 'bio-nature' ? 'png' : 'jpg'}`;
  img.onload = () => { imgsLoaded++; };
  IMGS[key] = img;
});

/* ── Frame layout ── */
let frames = [];

function initFrames() {
  // Mirror the original GIF composition roughly:
  // GIF has frames scattered from top-left to bottom-right
  const cx = W * 0.5, cy = H * 0.48;
  const rx = Math.min(W, H) * 0.33;
  const ry = Math.min(W, H) * 0.38;

  const positions = [
    { x: cx - rx * 0.5,  y: cy - ry * 0.88 },  // top-center (butterfly → liver)
    { x: cx + rx * 0.62, y: cy - ry * 0.65 },  // top-right (hand → brain)
    { x: cx - rx * 0.85, y: cy - ry * 0.1  },  // mid-left (lizard → membrane)
    { x: cx + rx * 0.78, y: cy + ry * 0.1  },  // mid-right (cell diagram)
    { x: cx - rx * 0.45, y: cy + ry * 0.75 },  // bottom-left (seal → pancreas)
    { x: cx + rx * 0.38, y: cy + ry * 0.8  },  // bottom-right (bird → life)
    { x: cx + rx * 0.05, y: cy - ry * 0.02 },  // center (floating → fat)
  ];

  frames = ORGANS.map((org, i) => ({
    ...org,
    x: positions[i].x,
    y: positions[i].y,
    baseX: positions[i].x,
    baseY: positions[i].y,
    floatPhase: Math.random() * Math.PI * 2,
    floatSpeed: 0.35 + Math.random() * 0.25,
    size: org.shape === 'square' ? 72 : 64,
    hover: false,
    state: 'organ',  // 'organ' | 'molecule'
  }));
}

window.addEventListener('resize', resize);
resize();

/* ── Interactions ── */
function hitFrame(px, py) {
  for (const f of frames) {
    const dx = px - f.x, dy = py - f.y;
    const hw = f.size / 2;
    const hit = f.shape === 'square'
      ? Math.abs(dx) < hw + 6 && Math.abs(dy) < hw + 6
      : dx * dx + dy * dy < (hw + 6) ** 2;
    if (hit) return f;
  }
  return null;
}

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
  const hit = hitFrame(mouse.x, mouse.y);
  frames.forEach(f => f.hover = f === hit);
  canvas.style.cursor = hit ? 'pointer' : 'default';
});

canvas.addEventListener('click', e => {
  const r = canvas.getBoundingClientRect();
  const hit = hitFrame(e.clientX - r.left, e.clientY - r.top);
  if (!hit) return;
  hit.state = hit.state === 'organ' ? 'molecule' : 'organ';
  showModal(hit);
});

document.getElementById('kg-close')?.addEventListener('click', () => {
  document.getElementById('kg-modal').classList.remove('open');
});
document.getElementById('kg-modal')?.addEventListener('click', e => {
  if (e.target.id === 'kg-modal') document.getElementById('kg-modal').classList.remove('open');
});

function showModal(frame) {
  const content = document.getElementById('kg-content');
  content.innerHTML = `
    <h2 style="color:#a78bfa;margin:0 0 0.7rem;font-size:1.25rem">${frame.label}</h2>
    <p style="color:#94a3b8;font-size:0.83rem;margin:0 0 1.2rem;line-height:1.6">${frame.desc}</p>
    <div style="display:flex;flex-wrap:wrap;gap:0.45rem">
      ${frame.molecules.map(m => `<span style="background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.4);color:#a78bfa;padding:0.28rem 0.85rem;border-radius:999px;font-size:0.8rem;font-family:monospace">${m}</span>`).join('')}
    </div>
  `;
  document.getElementById('kg-modal').classList.add('open');
}

/* ── Draw frame ── */
function drawFrame(f, time) {
  f.y = f.baseY + Math.sin(time * f.floatSpeed + f.floatPhase) * 6;

  const hw = f.size / 2;
  ctx.save();
  ctx.translate(f.x, f.y);

  // Clip to shape
  ctx.beginPath();
  if (f.shape === 'square') {
    ctx.rect(-hw, -hw, f.size, f.size);
  } else {
    ctx.arc(0, 0, hw, 0, Math.PI * 2);
  }
  ctx.save();
  ctx.clip();

  // Draw bio image if loaded
  const imgEl = IMGS[f.img];
  if (imgEl && imgEl.complete && imgEl.naturalWidth > 0) {
    // Fit image to frame (cover)
    const iw = imgEl.naturalWidth, ih = imgEl.naturalHeight;
    const scale = Math.max(f.size / iw, f.size / ih);
    const sw = iw * scale, sh = ih * scale;
    ctx.drawImage(imgEl, -sw / 2, -sh / 2, sw, sh);
  } else {
    // Fallback solid
    ctx.fillStyle = f.color + '33';
    if (f.shape === 'square') ctx.fillRect(-hw, -hw, f.size, f.size);
    else { ctx.beginPath(); ctx.arc(0, 0, hw, 0, Math.PI * 2); ctx.fill(); }
  }

  // Molecule state overlay
  if (f.state === 'molecule') {
    ctx.fillStyle = 'rgba(10,5,30,0.72)';
    if (f.shape === 'square') ctx.fillRect(-hw, -hw, f.size, f.size);
    else { ctx.beginPath(); ctx.arc(0, 0, hw, 0, Math.PI * 2); ctx.fill(); }

    // Draw molecule tags
    const mols = f.molecules.slice(0, 4);
    ctx.font = `bold ${Math.max(7, f.size * 0.13)}px monospace`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    mols.forEach((m, i) => {
      const angle = (i / mols.length) * Math.PI * 2 - Math.PI / 2;
      const r2 = f.size * 0.28;
      const mx = Math.cos(angle) * r2;
      const my = Math.sin(angle) * r2;
      // Bond line from center
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(mx * 0.6, my * 0.6);
      ctx.strokeStyle = 'rgba(167,139,250,0.4)';
      ctx.lineWidth = 1;
      ctx.stroke();
      // Atom circle
      ctx.beginPath();
      ctx.arc(mx, my, f.size * 0.1, 0, Math.PI * 2);
      ctx.fillStyle = ['#a78bfa','#06b6d4','#34d399','#fbbf24'][i % 4];
      ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,0.9)';
      ctx.fillText(m.length > 6 ? m.slice(0,5)+'…' : m, mx, my + f.size * 0.16);
    });
  }

  ctx.restore(); // unclip

  // Frame border
  ctx.beginPath();
  if (f.shape === 'square') {
    ctx.rect(-hw, -hw, f.size, f.size);
  } else {
    ctx.arc(0, 0, hw, 0, Math.PI * 2);
  }
  ctx.strokeStyle = f.hover
    ? 'rgba(167,139,250,0.95)'
    : (f.shape === 'square' ? 'rgba(240,230,210,0.75)' : 'rgba(220,205,170,0.7)');
  ctx.lineWidth = f.hover ? 2.5 : 1.5;
  ctx.stroke();

  // Hover glow
  if (f.hover) {
    ctx.globalAlpha = 0.18;
    ctx.beginPath();
    if (f.shape === 'square') ctx.rect(-hw - 8, -hw - 8, f.size + 16, f.size + 16);
    else ctx.arc(0, 0, hw + 10, 0, Math.PI * 2);
    ctx.fillStyle = '#a78bfa';
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  // Label below frame
  ctx.fillStyle = f.shape === 'square'
    ? 'rgba(240,225,200,0.9)'
    : 'rgba(240,225,200,0.9)';
  ctx.font = `600 ${Math.max(9, f.size * 0.16)}px sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.shadowColor = 'rgba(0,0,0,0.8)';
  ctx.shadowBlur = 6;
  ctx.fillText(f.label, 0, hw + 5);
  ctx.shadowBlur = 0;

  ctx.restore();
}

/* ── Draw thin connecting lines + red sphere (mirror GIF layout) ── */
function drawConnections(time) {
  const cx = W * 0.5, cy = H * 0.46;

  frames.forEach((f, i) => {
    ctx.save();
    ctx.beginPath();
    const cp1x = cx + (f.x - cx) * 0.4 + Math.sin(time * 0.5 + i) * 20;
    const cp1y = cy + (f.y - cy) * 0.4 + Math.cos(time * 0.4 + i) * 15;
    ctx.moveTo(cx, cy);
    ctx.quadraticCurveTo(cp1x, cp1y, f.x, f.y);
    ctx.strokeStyle = `rgba(190,50,50,${0.2 + Math.sin(time + i) * 0.05})`;
    ctx.lineWidth = 0.8;
    ctx.setLineDash([5, 10]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Traveling dot
    const dotT = ((time * 0.35 + i * 0.18) % 1 + 1) % 1;
    const dotX = (1-dotT)*(1-dotT)*cx + 2*(1-dotT)*dotT*cp1x + dotT*dotT*f.x;
    const dotY = (1-dotT)*(1-dotT)*cy + 2*(1-dotT)*dotT*cp1y + dotT*dotT*f.y;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 2, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(220,70,70,0.7)`;
    ctx.fill();
    ctx.restore();
  });

  // Central red sphere
  const pulse = 1 + Math.sin(time * 1.3) * 0.07;
  const sr = 14 * pulse;
  const grd = ctx.createRadialGradient(cx - 4, cy - 4, 1, cx, cy, sr);
  grd.addColorStop(0, '#ff8080');
  grd.addColorStop(0.5, '#cc2222');
  grd.addColorStop(1, '#7a0000');
  ctx.beginPath();
  ctx.arc(cx, cy, sr, 0, Math.PI * 2);
  ctx.fillStyle = grd;
  ctx.fill();
  // Outer glow
  ctx.beginPath();
  ctx.arc(cx, cy, sr * 2, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(180,30,30,0.12)';
  ctx.fill();
}

/* ── Main loop ── */
function animate() {
  t += 0.014;
  ctx.clearRect(0, 0, W, H);

  drawConnections(t);

  // Back frames (above center y)
  frames.filter(f => f.baseY < H * 0.5).forEach(f => drawFrame(f, t));
  // Front frames (below center y)
  frames.filter(f => f.baseY >= H * 0.5).forEach(f => drawFrame(f, t));

  requestAnimationFrame(animate);
}
requestAnimationFrame(animate);
</script>

<style>
.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
}

/* Original GIF background — cover, centered */
.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* Slight darkening overlay so text is readable */
.hero-bg-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10,5,25,0.3);
}

#scene-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-overlay {
  position: relative;
  z-index: 10;
  padding: 2rem 2.5rem;
  max-width: 320px;
  pointer-events: none;
}

.badge {
  display: inline-block;
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #67e8f9;
  border: 1px solid rgba(103,232,249,0.35);
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  margin-bottom: 0.9rem;
  background: rgba(6,182,212,0.08);
}

.hero-text h1 {
  font-size: clamp(2.6rem, 5vw, 4.5rem);
  line-height: 1;
  margin: 0 0 1rem;
  background: linear-gradient(135deg, #f8fafc 0%, #c4b5fd 55%, #67e8f9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  letter-spacing: -0.02em;
  text-shadow: none;
  filter: drop-shadow(0 2px 12px rgba(0,0,0,0.5));
}

.hero-text p {
  color: rgba(220,210,240,0.85);
  font-size: 0.86rem;
  line-height: 1.7;
  margin: 0 0 1.4rem;
  white-space: pre-line;
  text-shadow: 0 1px 6px rgba(0,0,0,0.7);
}

.hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  color: white;
  padding: 0.65rem 1.7rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.84rem;
  box-shadow: 0 0 22px rgba(124,58,237,0.5);
  pointer-events: all;
  transition: transform 0.2s, box-shadow 0.2s;
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 36px rgba(124,58,237,0.7);
  color: white;
  text-decoration: none;
}

.click-hint {
  position: absolute;
  bottom: 1.8rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(220,200,240,0.55);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  animation: hint-fade 2.5s ease-in-out infinite;
  white-space: nowrap;
  z-index: 10;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
@keyframes hint-fade {
  0%, 100% { opacity: 0.3; } 50% { opacity: 0.9; }
}

/* Modal */
.kg-modal {
  position: absolute;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7,5,20,0);
  pointer-events: none;
  transition: background 0.3s;
}
.kg-modal.open {
  background: rgba(7,5,20,0.82);
  pointer-events: all;
  backdrop-filter: blur(10px);
}
.kg-modal-panel {
  position: relative;
  width: min(460px, 90vw);
  background: rgba(12,8,32,0.97);
  border: 1px solid rgba(124,58,237,0.45);
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 0 60px rgba(124,58,237,0.3);
  transform: scale(0.85) translateY(16px);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s;
}
.kg-modal.open .kg-modal-panel {
  transform: scale(1) translateY(0);
  opacity: 1;
}
.kg-close {
  position: absolute;
  top: 1rem; right: 1.1rem;
  background: none; border: none;
  color: #94a3b8; font-size: 1.1rem;
  cursor: pointer; padding: 0.2rem 0.5rem; border-radius: 6px;
}
.kg-close:hover { color: #06b6d4; background: rgba(6,182,212,0.1); }
</style>
