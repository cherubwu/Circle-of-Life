---
import KnowledgeGraph from './KnowledgeGraph.astro';
const lang = Astro.currentLocale ?? 'en';
---

<section class="hero-scene" id="hero-scene">
  <canvas id="scene-canvas"></canvas>

  <div class="scene-layout">
    <!-- Left: title + girl + orbiting planets -->
    <div class="scene-left">
      <div class="hero-text">
        <span class="badge">Biotech · Neuroscience · 2025</span>
        <h1>{lang === 'zh' ? <>生之<br/>回环</> : <>Circle<br/>of Life</>}</h1>
        <p>
          {lang === 'zh'
            ? '研究者视角的生命科学洞见，聚焦创新药与神经科学前沿。'
            : 'Biotech insights from inside the lab.\nInnovative drugs · Neuroscience · Metabolism.'}
        </p>
        <a href="https://your-substack.substack.com" target="_blank" class="hero-cta">
          {lang === 'zh' ? '订阅周刊 →' : 'Subscribe →'}
        </a>
      </div>

      <!-- Girl image — canvas draws planets around this element -->
      <div class="girl-area" id="girl-area">
        <div class="girl-glow"></div>
        <img src="/Circle-of-Life/girl-mascot.jpg" class="girl-img" alt="mascot" />
      </div>
    </div>

    <!-- Right: Knowledge Graph -->
    <div class="scene-right">
      <div class="graph-panel">
        <KnowledgeGraph />
      </div>
    </div>
  </div>
</section>

<script>
const canvas = document.getElementById('scene-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
let W = 0, H = 0;
const mouse = { x: -9999, y: -9999 };

function resize() {
  W = canvas.width = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
}
resize();
window.addEventListener('resize', resize);
window.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouse.x = e.clientX - r.left;
  mouse.y = e.clientY - r.top;
});

/* ── Stars ── */
const stars = Array.from({ length: 300 }, () => ({
  x: Math.random(), y: Math.random(),
  r: Math.random() * 1.5 + 0.2,
  a: Math.random(),
  da: (Math.random() * 0.007 + 0.001) * (Math.random() > 0.5 ? 1 : -1),
}));

/* ── Planets ── */
// Each planet travels on a tilted ellipse around the girl
// Semi-major = a, semi-minor = b, tilt = angle of ellipse rotation
const PLANET_DEFS = [
  { label: 'GLP-1',  r: 18, top: '#f97316', bot: '#7c2d12', ring: false },
  { label: 'BCI',    r: 14, top: '#a78bfa', bot: '#4c1d95', ring: true,  ringCol: 'rgba(167,139,250,0.55)' },
  { label: 'MASH',   r: 16, top: '#34d399', bot: '#064e3b', ring: false },
  { label: 'DNA',    r: 12, top: '#60a5fa', bot: '#1e3a8a', ring: false },
  { label: 'mTOR',   r: 13, top: '#f0abfc', bot: '#701a75', ring: false },
  { label: 'ATP',    r: 11, top: '#fde68a', bot: '#92400e', ring: false },
  { label: 'RNA',    r: 10, top: '#6ee7b7', bot: '#065f46', ring: false },
  { label: 'Tau',    r: 14, top: '#93c5fd', bot: '#1e40af', ring: true,  ringCol: 'rgba(147,197,253,0.5)' },
  { label: 'BDNF',   r: 12, top: '#fb923c', bot: '#7c2d12', ring: false },
  { label: 'CRISPR', r: 15, top: '#c084fc', bot: '#581c87', ring: true,  ringCol: 'rgba(192,132,252,0.5)' },
  { label: 'p53',    r: 11, top: '#4ade80', bot: '#14532d', ring: false },
  { label: 'IL-6',   r: 10, top: '#f87171', bot: '#7f1d1d', ring: false },
];

// Two elliptical orbits (inner + outer belt), tilted diagonally like the ref image
const ORBITS = [
  { a: 140, b: 55,  tilt: -0.45, speed: 0.0045, offset: 0 },      // inner belt
  { a: 195, b: 75,  tilt: -0.38, speed: 0.0030, offset: Math.PI }, // outer belt
];

const planets = PLANET_DEFS.map((def, i) => {
  const orb = ORBITS[i % 2];
  return {
    ...def,
    orb,
    t: (i / PLANET_DEFS.length) * Math.PI * 2 * (i % 2 === 0 ? 1 : -1),
    x: 0, y: 0,
    pushX: 0, pushY: 0,
  };
});

function getGirlCenter() {
  const el = document.getElementById('girl-area');
  if (!el) return { x: W * 0.42, y: H * 0.5 };
  const rect = el.getBoundingClientRect();
  const cr = canvas.getBoundingClientRect();
  return {
    x: rect.left + rect.width * 0.5 - cr.left,
    y: rect.top  + rect.height * 0.5 - cr.top,
  };
}

function drawOrbitBelt(gx: number, gy: number) {
  ORBITS.forEach(orb => {
    ctx.save();
    ctx.translate(gx, gy);
    ctx.rotate(orb.tilt);
    ctx.scale(1, orb.b / orb.a);
    ctx.beginPath();
    ctx.arc(0, 0, orb.a, 0, Math.PI * 2);
    ctx.restore();
    ctx.strokeStyle = 'rgba(167,139,250,0.1)';
    ctx.lineWidth = 1;
    ctx.stroke();
  });
}

function drawPlanet(p: typeof planets[0]) {
  const { x, y, r, top, bot, label } = p;

  // Planet body
  const grad = ctx.createRadialGradient(x - r * 0.35, y - r * 0.35, r * 0.05, x + r * 0.1, y + r * 0.1, r);
  grad.addColorStop(0, top);
  grad.addColorStop(1, bot);
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fillStyle = grad;
  ctx.fill();

  // Atmosphere glow
  const atm = ctx.createRadialGradient(x, y, r * 0.8, x, y, r * 1.45);
  atm.addColorStop(0, top.replace(')', ', 0.25)').replace('rgb', 'rgba').replace('#', 'rgba(').padEnd(10));
  // simplified: just use a semi-transparent ring
  ctx.beginPath();
  ctx.arc(x, y, r * 1.3, 0, Math.PI * 2);
  ctx.strokeStyle = top + '44';
  ctx.lineWidth = r * 0.35;
  ctx.globalAlpha = 0.25;
  ctx.stroke();
  ctx.globalAlpha = 1;

  // Saturn-style ring
  if ((p as any).ring) {
    ctx.save();
    ctx.translate(x, y);
    ctx.scale(1, 0.28);
    ctx.beginPath();
    ctx.arc(0, 0, r * 1.85, 0, Math.PI * 2);
    ctx.strokeStyle = (p as any).ringCol;
    ctx.lineWidth = r * 0.55;
    ctx.stroke();
    // Clip center of ring (behind planet)
    ctx.restore();
  }

  // Re-draw planet on top of ring clipping area
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fillStyle = grad;
  ctx.fill();

  // Surface highlight
  ctx.beginPath();
  ctx.arc(x - r * 0.28, y - r * 0.28, r * 0.45, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(255,255,255,0.18)';
  ctx.fill();

  // Label
  ctx.fillStyle = 'rgba(255,255,255,0.92)';
  ctx.font = `bold ${Math.max(7, r * 0.55)}px monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(label, x, y + r * 0.08);
}

function animate() {
  ctx.clearRect(0, 0, W, H);

  // Deep space background
  const bg = ctx.createLinearGradient(0, 0, W * 0.5, H);
  bg.addColorStop(0, '#08081a');
  bg.addColorStop(0.6, '#0f0f1e');
  bg.addColorStop(1, '#0a0d1f');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Stars
  stars.forEach(s => {
    s.a += s.da;
    if (s.a > 1 || s.a < 0.05) s.da *= -1;
    ctx.beginPath();
    ctx.arc(s.x * W, s.y * H, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(255,255,255,${s.a})`;
    ctx.fill();
  });

  const { x: gx, y: gy } = getGirlCenter();

  // Nebula around girl
  const neb = ctx.createRadialGradient(gx, gy, 0, gx, gy, 260);
  neb.addColorStop(0, 'rgba(124,58,237,0.10)');
  neb.addColorStop(0.4, 'rgba(6,182,212,0.05)');
  neb.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = neb;
  ctx.fillRect(0, 0, W, H);

  // Subtle orbit belts
  drawOrbitBelt(gx, gy);

  // Update + draw planets (back → front by y depth)
  const sorted = [...planets].sort((a, b) => a.y - b.y);

  planets.forEach(p => {
    p.t += p.orb.speed;
    const cos = Math.cos(p.orb.tilt);
    const sin = Math.sin(p.orb.tilt);
    const ex = Math.cos(p.t) * p.orb.a;
    const ey = Math.sin(p.t) * p.orb.b;
    const baseX = gx + ex * cos - ey * sin;
    const baseY = gy + ex * sin + ey * cos;

    // Mouse repulsion
    const dx = baseX - mouse.x;
    const dy = baseY - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const push = dist < 130 && dist > 1 ? ((130 - dist) / 130) * 35 : 0;
    p.x = baseX + (dx / dist) * push;
    p.y = baseY + (dy / dist) * push;
  });

  // Draw back-half planets first (behind girl)
  sorted.filter(p => p.y < gy).forEach(drawPlanet);
  // (girl image is drawn by CSS, over canvas)
  // Draw front-half planets (in front of girl)
  sorted.filter(p => p.y >= gy).forEach(drawPlanet);

  requestAnimationFrame(animate);
}
requestAnimationFrame(animate);
</script>

<style>
.hero-scene {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 640px;
  overflow: hidden;
}

#scene-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.scene-layout {
  position: relative;
  z-index: 10;
  display: flex;
  height: 100%;
  padding: 0 3rem;
  max-width: 1300px;
  margin: 0 auto;
  align-items: center;
}

/* ─── Left ─── */
.scene-left {
  flex: 0 0 55%;
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  position: absolute;
  top: 13%;
  left: 0;
  z-index: 20;
  max-width: 270px;
}

.badge {
  display: inline-block;
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent-2);
  border: 1px solid rgba(6,182,212,0.35);
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  margin-bottom: 1rem;
  background: rgba(6,182,212,0.06);
}

.hero-text h1 {
  font-size: clamp(2.8rem, 5vw, 5rem);
  line-height: 1;
  margin: 0 0 1rem;
  background: linear-gradient(135deg, #f1f5f9 0%, #a78bfa 55%, #06b6d4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.hero-text p {
  color: var(--text-muted);
  font-size: 0.88rem;
  line-height: 1.7;
  margin: 0 0 1.5rem;
  white-space: pre-line;
}

.hero-cta {
  display: inline-block;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  color: white;
  padding: 0.7rem 1.8rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.85rem;
  box-shadow: 0 0 24px rgba(124,58,237,0.45);
  transition: transform 0.2s, box-shadow 0.2s;
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 36px rgba(124,58,237,0.65);
  color: white;
  text-decoration: none;
}

/* Girl image */
.girl-area {
  position: relative;
  width: 260px;
  height: 260px;
  margin-left: 60px;
  z-index: 15;
}

.girl-glow {
  position: absolute;
  inset: -50px;
  background: radial-gradient(ellipse at center, rgba(124,58,237,0.2) 0%, transparent 65%);
  border-radius: 50%;
  animation: pulse-glow 3.5s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.06); }
}

.girl-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;
  animation: float 4.5s ease-in-out infinite;
  filter: drop-shadow(0 0 22px rgba(124,58,237,0.6));
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-14px); }
}

/* ─── Right ─── */
.scene-right {
  flex: 0 0 43%;
  display: flex;
  align-items: center;
}

.graph-panel {
  width: 100%;
  background: rgba(10,10,25,0.6);
  border: 1px solid rgba(45,45,78,0.8);
  border-radius: 16px;
  padding: 1rem 1.2rem;
  backdrop-filter: blur(10px);
  box-shadow: 0 0 30px rgba(124,58,237,0.08);
}

.graph-panel :global(.kg-wrapper) { margin: 0; }
.graph-panel :global(.kg-title) { font-size: 1rem; }

@media (max-width: 900px) {
  .scene-layout { flex-direction: column; height: auto; padding: 2rem 1.5rem; gap: 2rem; }
  .scene-left { height: auto; min-height: 500px; }
  .scene-right { width: 100%; }
  .hero-text { position: static; max-width: 100%; margin-bottom: 1.5rem; }
  .girl-area { margin: 0 auto; }
}
</style>
