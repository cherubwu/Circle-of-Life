---
const year = new Date().getFullYear();
---
<div class="footer-stripe" aria-hidden="true">
  <span style="background:#6ecfa0"></span>
  <span style="background:#5bbad5"></span>
  <span style="background:#9c88d4"></span>
  <span style="background:#e07bb0"></span>
  <span style="background:#e8a050"></span>
</div>
<footer>
  <p class="footer-copy">© {year} 生之回环 · Circle of Life</p>
  <p class="footer-disclaimer">内容仅供学术交流，不构成投资建议。</p>
</footer>

<style>
.footer-stripe {
  display: flex;
  width: 100%;
  height: 6px;
}
.footer-stripe span { flex: 1; }

footer {
  background: #1a1a2e;
  text-align: center;
  padding: 2.5rem 1rem;
  border-top: none;
}
.footer-copy {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #f5f0e8;
  margin: 0 0 0.4rem;
}
.footer-disclaimer {
  font-size: 0.78rem;
  color: #9c88d4;
  margin: 0;
  letter-spacing: 0.04em;
}
</style>
