---
const year = new Date().getFullYear();
---
<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Circle of Life</span>
      <span class="footer-tagline">生之回环</span>
    </div>
    <div class="footer-links">
      <a href="/Circle-of-Life/blog">Articles</a>
      <a href="/Circle-of-Life/about">About</a>
      <a href="https://your-substack.substack.com" target="_blank">Subscribe</a>
    </div>
    <div class="footer-copy">
      <p>© {year} Circle of Life · 生之回环</p>
      <p class="footer-disclaimer">内容仅供学术交流，不构成投资建议。</p>
    </div>
  </div>
  <div class="footer-bar">
    <span style="background:#EF5B5B"></span>
    <span style="background:#F7E623"></span>
    <span style="background:#3D50B3"></span>
    <span style="background:#E61E8D"></span>
    <span style="background:#1d8a78"></span>
  </div>
</footer>

<style>
@import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:wght@400;500;600&display=swap');

footer {
  background: #F2EFE6;
  border-top: 3px solid #000;
  margin-top: 0;
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3rem 4vw 2.5rem;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 2rem;
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.footer-logo {
  font-family: 'Archivo Black', sans-serif;
  font-size: 1.3rem;
  text-transform: uppercase;
  color: #000;
  letter-spacing: 0.05em;
}
.footer-tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  color: rgba(0,0,0,0.45);
  letter-spacing: 0.12em;
}

.footer-links {
  display: flex;
  gap: 0;
  border: 2px solid #000;
}
.footer-links a {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #000;
  text-decoration: none;
  padding: 0.6rem 1.2rem;
  border-right: 1px solid #000;
  transition: background 0.12s, color 0.12s;
}
.footer-links a:last-child { border-right: none; }
.footer-links a:hover { background: #000; color: #F2EFE6; }

.footer-copy {
  text-align: right;
}
.footer-copy p {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  color: rgba(0,0,0,0.55);
  margin: 0.15rem 0;
  letter-spacing: 0.06em;
}
.footer-disclaimer {
  font-size: 0.62rem !important;
  color: rgba(0,0,0,0.35) !important;
}

/* Neo-brutalist bottom colour bar */
.footer-bar {
  display: flex;
  width: 100%;
  height: 8px;
  border-top: 2px solid #000;
}
.footer-bar span { flex: 1; }

@media (max-width: 640px) {
  .footer-inner { grid-template-columns: 1fr; text-align: center; }
  .footer-copy { text-align: center; }
  .footer-links { justify-content: center; }
}
</style>
